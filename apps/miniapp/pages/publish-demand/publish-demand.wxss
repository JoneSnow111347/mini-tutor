.inline-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.mode-row {
  display: flex;
  gap: 14rpx;
}

.mode-chip {
  flex: 1;
  height: 70rpx;
  border-radius: 22rpx;
  background: #f0f3f7;
  color: #5d6675;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 70rpx;
  text-align: center;
}

.mode-chip.active {
  background: #111827;
  color: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(17, 24, 39, 0.18);
}

.privacy-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.last-field {
  margin-bottom: 0;
}

.submit-button {
  margin-top: 8rpx;
  margin-bottom: 48rpx;
}
