<view class="container">
  <view class="ios-hero">
    <text class="title">发布需求</text>
    <text class="subtitle">填写信息，老师会主动联系你</text>
  </view>

  <!-- 基本信息 -->
  <view class="card">
    <view class="section-label">基本信息</view>

    <view class="inline-grid">
      <view class="form-group">
        <text class="form-label">科目<text class="required">*</text></text>
        <input class="form-input" maxlength="30" placeholder="数学" placeholder-class="placeholder" value="{{subject}}" bindinput="onSubjectInput" />
        <text wx:if="{{fieldErrors.subject}}" class="field-error">{{fieldErrors.subject}}</text>
      </view>
      <view class="form-group">
        <text class="form-label">年级<text class="required">*</text></text>
        <input class="form-input" maxlength="30" placeholder="初二" placeholder-class="placeholder" value="{{grade_level}}" bindinput="onGradeInput" />
        <text wx:if="{{fieldErrors.grade_level}}" class="field-error">{{fieldErrors.grade_level}}</text>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">需求标题<text class="required">*</text></text>
      <input class="form-input" maxlength="50" placeholder="如：初二数学周末辅导" placeholder-class="placeholder" value="{{title}}" bindinput="onTitleInput" />
      <text class="form-hint">一句话概括辅导需求</text>
      <text wx:if="{{fieldErrors.title}}" class="field-error">{{fieldErrors.title}}</text>
    </view>
  </view>

  <!-- 上课安排 -->
  <view class="card">
    <view class="section-label">上课安排</view>

    <view class="form-group">
      <text class="form-label">上课方式<text class="required">*</text></text>
      <view class="mode-row">
        <view wx:for="{{classModeOptions}}" wx:key="*this" class="mode-chip {{class_mode === item ? 'active' : ''}}" data-mode="{{item}}" bindtap="selectClassMode">{{item}}</view>
      </view>
    </view>

    <view class="inline-grid">
      <view class="form-group">
        <text class="form-label">区域<text class="required">*</text></text>
        <input class="form-input" maxlength="50" placeholder="如：洪山区" placeholder-class="placeholder" value="{{area}}" bindinput="onAreaInput" />
        <text wx:if="{{fieldErrors.area}}" class="field-error">{{fieldErrors.area}}</text>
      </view>
      <view class="form-group">
        <view class="row-head-compact">
          <text class="form-label">详细地址</text>
          <text class="location-pick" bindtap="chooseLocation">定位</text>
        </view>
        <input class="form-input" maxlength="80" placeholder="选填" placeholder-class="placeholder" value="{{address}}" bindinput="onAddressInput" />
      </view>
    </view>

    <view wx:if="{{latitude !== null && longitude !== null}}" class="location-bar">
      <text class="location-text">已定位</text>
      <text class="location-clear" bindtap="clearLocation">清除</text>
    </view>
  </view>

  <!-- 详细说明 -->
  <view class="card">
    <view class="section-label">详细说明</view>

    <view class="form-group last-field">
      <textarea class="form-textarea" maxlength="500" placeholder="学生基础如何、哪些知识点薄弱、希望怎么辅导" placeholder-class="placeholder" value="{{description}}" bindinput="onDescInput" />
      <text class="char-count">{{description.length}} / 500</text>
      <text wx:if="{{fieldErrors.description}}" class="field-error">{{fieldErrors.description}}</text>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="card">
    <view class="section-label">联系方式</view>

    <view class="form-group">
      <text class="form-label">联系人<text class="required">*</text></text>
      <input class="form-input" maxlength="20" placeholder="如：李女士" placeholder-class="placeholder" value="{{contact_name}}" bindinput="onContactNameInput" />
      <text wx:if="{{fieldErrors.contact_name}}" class="field-error">{{fieldErrors.contact_name}}</text>
    </view>

    <view class="form-group last-field">
      <text class="form-label">联系电话<text class="required">*</text></text>
      <input class="form-input" type="number" maxlength="11" placeholder="11 位手机号" placeholder-class="placeholder" value="{{contact_phone}}" bindinput="onContactPhoneInput" />
      <text wx:if="{{fieldErrors.contact_phone}}" class="field-error">{{fieldErrors.contact_phone}}</text>
    </view>

    <view class="privacy-note">
      <text class="privacy-label">隐私保护</text>
      <text class="privacy-desc">仅已被接受的老师可查看联系方式</text>
    </view>
  </view>

  <button class="btn-primary submit-button" disabled="{{loading}}" loading="{{loading}}" bindtap="handleSubmit">
    {{loading ? '发布中...' : '发布需求'}}
  </button>
  <text class="submit-hint">发布后可在"我的需求"中查看和管理</text>
</view>
