.demand-main {
  flex: 1;
  min-width: 0;
}

.goto-hint,
.back-btn {
  display: block;
  margin-top: 16rpx;
  color: #FF6B6B;
  font-size: 24rpx;
  font-weight: 500;
}

.back-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 18rpx;
}

.back-icon {
  color: #FF6B6B;
  font-size: 28rpx;
  font-weight: 600;
}

.back-text {
  color: #FF6B6B;
  font-size: 26rpx;
  font-weight: 500;
}

.apply-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.teacher-name {
  display: block;
  color: #1A1714;
  font-size: 32rpx;
  font-weight: 600;
}

.teacher-subjects {
  display: block;
  margin-top: 8rpx;
  color: #8C857D;
  font-size: 24rpx;
  line-height: 1.5;
}

.badge-col {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.fav-teacher-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 14rpx;
}

.fav-teacher-btn {
  min-height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 142, 83, 0.12);
  background: #FFFFFF;
  color: #8C857D;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 56rpx;
  transition: transform 0.15s;
}

.fav-teacher-btn:active {
  transform: scale(0.95);
}

.fav-teacher-active {
  border-color: rgba(255, 107, 107, 0.3);
  background: #FFF5F2;
  color: #FF6B6B;
}

.goto-hint.small {
  font-size: 22rpx;
}

.message-box {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #FAFAF8;
  color: #5A5550;
  font-size: 28rpx;
  line-height: 1.6;
}

.apply-actions {
  margin-top: 22rpx;
}

.detail-link {
  display: block;
  margin-bottom: 16rpx;
  color: #FF6B6B;
  font-size: 24rpx;
  font-weight: 500;
  text-align: right;
}

.decision-row {
  display: flex;
  gap: 16rpx;
}

.decision-btn {
  flex: 1;
  min-height: 72rpx;
  line-height: 72rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.empty-main {
  display: block;
  color: #5A5550;
  font-size: 28rpx;
  font-weight: 600;
}

.empty-sub {
  display: block;
  margin-top: 8rpx;
  color: #9A938B;
  font-size: 24rpx;
}

.close-button {
  margin-top: 18rpx;
  height: 68rpx;
  border-radius: 18rpx;
  border: 2rpx solid #E8E5E0;
  background: #FAFAF8;
  color: #8C857D;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 68rpx;
  transition: transform 0.15s;
}

.close-button:active {
  transform: scale(0.96);
}

.card-updated {
  border-color: rgba(255, 107, 107, 0.2);
  box-shadow: 0 2rpx 16rpx rgba(255, 107, 107, 0.08);
}
