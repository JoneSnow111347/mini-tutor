.demand-main {
  flex: 1;
  min-width: 0;
}

.goto-hint,
.back-btn {
  display: block;
  margin-top: 20rpx;
  color: #007aff;
  font-size: 25rpx;
  font-weight: 700;
}

.selected-card {
  animation: slide-down 0.3s ease both;
}

.apply-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.teacher-name {
  display: block;
  color: #111827;
  font-size: 31rpx;
  font-weight: 750;
}

.teacher-subjects {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.badge-col {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.message-box {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f5f7fb;
  color: #374151;
  font-size: 25rpx;
  line-height: 1.55;
}

.apply-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 22rpx;
}

.apply-actions button {
  flex: 1;
}

.detail-btn {
  min-width: 0;
}

.close-button {
  margin-top: 20rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: #fff0f0;
  color: #d92d20;
  font-size: 25rpx;
  font-weight: 750;
  line-height: 72rpx;
}

@keyframes badge-flash {
  0% { transform: scale(1); }
  25% { transform: scale(1.28); box-shadow: 0 0 0 10rpx rgba(0, 122, 255, 0.16); }
  55% { transform: scale(0.94); }
  100% { transform: scale(1); }
}

.badge-flash {
  animation: badge-flash 0.75s ease both;
}

@keyframes card-update {
  0% { opacity: 0.88; transform: translateY(12rpx); }
  45% { opacity: 1; transform: translateY(0); box-shadow: 0 22rpx 52rpx rgba(0, 122, 255, 0.14); }
  100% { opacity: 1; transform: translateY(0); }
}

.card-updated {
  animation: card-update 0.65s ease both;
}
