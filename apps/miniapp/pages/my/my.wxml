<view class="my-page">
  <block wx:if="{{!userInfo}}">
    <view class="login-prompt">
      <text class="lp-title">未登录</text>
      <text class="lp-sub">登录后可查看收藏、订单、资料和通知。</text>
      <button class="btn-primary" bindtap="goLogin">立即登录</button>
    </view>
  </block>

  <block wx:else>
    <view class="profile-header">
      <view wx:if="{{badgeCount > 0}}" class="notification-badge {{badgeFlash ? 'badge-flash' : ''}}">
        {{badgeCount > 99 ? '99+' : badgeCount}}
      </view>
      <view class="avatar"><text>{{avatarText}}</text></view>
      <text class="nickname">{{nickname}}</text>
      <view class="badge-row role-row">
        <text class="badge badge-verified">{{role === 'teacher' ? '老师' : '家长/学生'}}</text>
        <text class="badge badge-open">基础用户</text>
      </view>
      <text class="phone">{{maskedPhone}}</text>
    </view>

    <view class="stats-card">
      <view wx:for="{{stats}}" wx:key="label" class="stat-item {{item.flash ? 'stat-flash' : ''}}" data-index="{{index}}" bindtap="goStat">
        <text class="stat-value">{{loading ? '-' : item.value}}</text>
        <text class="stat-label">{{item.label}}</text>
        <text class="stat-badge badge {{index === 2 ? 'badge-pending' : index === 1 ? 'badge-accepted' : 'badge-applied'}}">{{item.badge}}</text>
      </view>
    </view>

    <view class="menu-card">
      <view class="menu-item" bindtap="goFavorites">
        <text class="menu-label">我的收藏</text>
        <text wx:if="{{stats[0].value > 0}}" class="mini-badge {{stats[0].flash ? 'badge-flash' : ''}}">{{stats[0].value}}</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goRecords">
        <text class="menu-label">{{role === 'teacher' ? '申请/订单' : '需求/订单'}}</text>
        <text wx:if="{{stats[1].value > 0}}" class="mini-badge {{stats[1].flash ? 'badge-flash' : ''}}">{{stats[1].value}}</text>
        <text class="menu-arrow">></text>
      </view>
      <view wx:if="{{role === 'teacher'}}" class="menu-item" bindtap="goProfile">
        <text class="menu-label">编辑老师资料</text>
        <text class="menu-arrow">></text>
      </view>
      <view wx:else class="menu-item" bindtap="goPublishDemand">
        <text class="menu-label">发布需求</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item last" bindtap="goNotifications">
        <text class="menu-label">消息通知</text>
        <text wx:if="{{badgeCount > 0}}" class="mini-badge {{badgeFlash ? 'badge-flash' : ''}}">{{badgeCount > 99 ? '99+' : badgeCount}}</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <view class="menu-card">
      <view class="menu-item" bindtap="showProfileInfo">
        <text class="menu-label">个人资料</text>
        <text class="menu-sub">{{role === 'teacher' ? '老师' : '家长/学生'}}</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="goIdentityVerify">
        <text class="menu-label">身份认证</text>
        <text class="menu-sub">{{identityStatusText}}</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item" bindtap="showTodo">
        <text class="menu-label">消息设置</text>
        <text class="menu-arrow">></text>
      </view>
      <view class="menu-item last" bindtap="showTodo">
        <text class="menu-label">帮助与反馈</text>
        <text class="menu-arrow">></text>
      </view>
    </view>

    <button class="btn-secondary logout-btn" bindtap="handleLogout">退出登录</button>
  </block>

  <button class="global-logout-btn" bindtap="handleGlobalLogout">退出登录</button>
</view>
