.my-page {
  min-height: 100vh;
  padding: 24rpx;
  background: #F7F6F3;
}

.login-prompt {
  min-height: 82vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  text-align: center;
}

.lp-title {
  color: #1A1714;
  font-size: 36rpx;
  font-weight: 700;
}

.lp-sub {
  margin: 16rpx 0 36rpx;
  color: #8C857D;
  font-size: 28rpx;
  line-height: 1.5;
}

.profile-header {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.notification-badge {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 36rpx;
  text-align: center;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 28rpx;
  border: 0;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 700;
  line-height: 100rpx;
  text-align: center;
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 107, 0.2);
}

.nickname {
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 600;
  color: #1A1714;
}

.role-row {
  justify-content: center;
}

.phone {
  margin-top: 10rpx;
  color: #8C857D;
  font-size: 24rpx;
}

.stats-card {
  display: flex;
  margin: 20rpx 0;
  border-radius: 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  background: #FFFFFF;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stat-item {
  flex: 1;
  padding: 24rpx 8rpx;
  text-align: center;
  transition: background 0.15s;
}

.stat-item:active,
.menu-item:active {
  background: #F5F5F3;
}

.stat-value {
  display: block;
  color: #1A1714;
  font-size: 36rpx;
  font-weight: 700;
}

.stat-label {
  display: block;
  margin-top: 6rpx;
  color: #8C857D;
  font-size: 24rpx;
}

.stat-badge {
  margin-top: 10rpx;
}

.menu-card {
  margin-bottom: 16rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  background: #FFFFFF;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.menu-item {
  display: flex;
  align-items: center;
  min-height: 92rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.04);
  transition: background 0.15s;
}

.menu-item.last {
  border-bottom: 0;
}

.menu-label {
  flex: 1;
  color: #2D2A26;
  font-size: 28rpx;
  font-weight: 500;
}

.menu-arrow {
  color: #C4BDB5;
  font-size: 28rpx;
}

.menu-sub {
  margin-right: 12rpx;
  color: #9A938B;
  font-size: 24rpx;
}

.mini-badge {
  min-width: 34rpx;
  height: 34rpx;
  margin-right: 12rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 34rpx;
  text-align: center;
}

.logout-divider {
  margin-top: 40rpx;
  margin-bottom: 24rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.06);
}

.logout-btn {
  border: 1rpx solid rgba(255, 59, 48, 0.12);
  background: rgba(255, 59, 48, 0.03);
  border-radius: 18rpx;
  color: #FF3B30;
  font-size: 26rpx;
  font-weight: 400;
  opacity: 0.8;
}

.logout-btn:active {
  opacity: 0.6;
  background: rgba(255, 59, 48, 0.06);
}
