.my-page {
  min-height: 100vh;
  padding: 32rpx;
  background: #f5f7fb;
}

.login-prompt {
  min-height: 82vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  text-align: center;
}

.lp-title {
  color: #111827;
  font-size: 42rpx;
  font-weight: 800;
}

.lp-sub {
  margin: 18rpx 0 44rpx;
  color: #6b7280;
  font-size: 27rpx;
}

.profile-header {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 32rpx;
  border-radius: 34rpx;
  background: linear-gradient(145deg, #007aff, #34c8ff);
  color: #ffffff;
  box-shadow: 0 20rpx 46rpx rgba(0, 122, 255, 0.22);
  animation: slide-down 0.3s ease both;
}

.notification-badge {
  position: absolute;
  top: 26rpx;
  right: 26rpx;
  min-width: 42rpx;
  height: 42rpx;
  padding: 0 10rpx;
  border-radius: 999rpx;
  background: #ff3b30;
  color: #ffffff;
  font-size: 21rpx;
  font-weight: 800;
  line-height: 42rpx;
  text-align: center;
}

.avatar {
  width: 118rpx;
  height: 118rpx;
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.92);
  color: #007aff;
  font-size: 50rpx;
  font-weight: 800;
  line-height: 118rpx;
  text-align: center;
}

.nickname {
  margin-top: 22rpx;
  font-size: 38rpx;
  font-weight: 800;
}

.role-row {
  justify-content: center;
}

.phone {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.78);
  font-size: 25rpx;
}

.stats-card {
  display: flex;
  margin: 24rpx 0;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 46rpx rgba(31, 41, 55, 0.08);
  overflow: hidden;
}

.stat-item {
  flex: 1;
  padding: 32rpx 8rpx;
  text-align: center;
  transition: background 0.2s, transform 0.2s;
}

.stat-item:active,
.menu-item:active {
  background: #f8fafc;
}

.stat-value {
  display: block;
  color: #111827;
  font-size: 44rpx;
  font-weight: 800;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
}

.stat-badge {
  margin-top: 14rpx;
}

.menu-card {
  margin-bottom: 22rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 46rpx rgba(31, 41, 55, 0.08);
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  min-height: 94rpx;
  padding: 0 28rpx;
  border-bottom: 1rpx solid #edf0f4;
}

.menu-item.last {
  border-bottom: 0;
}

.menu-label {
  flex: 1;
  color: #111827;
  font-size: 29rpx;
  font-weight: 650;
}

.menu-arrow {
  color: #b6beca;
  font-size: 28rpx;
}

.menu-sub {
  margin-right: 14rpx;
  color: #8a94a6;
  font-size: 24rpx;
}

.mini-badge {
  min-width: 34rpx;
  height: 34rpx;
  margin-right: 14rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #ff3b30;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 800;
  line-height: 34rpx;
  text-align: center;
  animation: badge-pop 0.32s ease both;
}

.logout-btn {
  margin-top: 10rpx;
}

@keyframes badge-flash {
  0% { transform: scale(1); }
  24% { transform: scale(1.3); box-shadow: 0 0 0 10rpx rgba(255, 59, 48, 0.16); }
  55% { transform: scale(0.94); }
  100% { transform: scale(1); }
}

.badge-flash {
  animation: badge-flash 0.75s ease both;
}

@keyframes stat-flash {
  0% { transform: translateY(0); background: #ffffff; }
  35% { transform: translateY(-6rpx); background: #eef5ff; }
  100% { transform: translateY(0); background: #ffffff; }
}

.stat-flash {
  animation: stat-flash 0.72s ease both;
}
