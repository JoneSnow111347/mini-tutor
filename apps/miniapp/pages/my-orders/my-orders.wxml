<view class="page">
  <view class="ios-hero">
    <text class="eyebrow">{{role === 'teacher' ? '教师' : '家长'}}</text>
    <text class="title">{{role === 'teacher' ? '我的申请' : '我的订单'}}</text>
    <text class="subtitle">{{role === 'teacher' ? '查看所有申请记录及接单状态。' : '管理已发布需求，查看申请进度。'}}</text>
  </view>
  <view class="tab-bar">
    <view class="tab-item {{activeTab === 'all' ? 'tab-active' : ''}}" data-tab="all" bindtap="switchTab">全部</view>
    <view class="tab-item {{activeTab === 'favorites' ? 'tab-active' : ''}}" data-tab="favorites" bindtap="switchTab">收藏</view>
  </view>
  <block wx:if="{{role !== 'teacher' && activeTab === 'all'}}">
    <view wx:if="{{loading}}" class="empty-tip">正在加载你的需求...</view>
    <view wx:elif="{{demands.length === 0}}" class="empty-tip">
      <text class="empty-main">还没有发布过需求</text>
      <text class="empty-sub">发布后老师可以申请，你在这里管理进度</text>
      <button class="btn-primary btn-sm empty-cta" bindtap="goPublish">发布需求</button>
    </view>
    <view wx:for="{{demands}}" wx:key="id" class="card demand-card {{closingDemandId === item.id ? 'card-closing' : ''}}">
      <view class="card-row">
        <view class="demand-main">
          <text class="card-title">{{item.title}}</text>
          <text class="card-meta">{{item.subject}} · {{item.grade_level}} · {{item.class_mode}}</text>
        </view>
        <text class="badge badge-{{item.displayStatus}} {{item.statusChanged ? 'badge-flash' : ''}}">{{item.statusText}}</text>
      </view>
      <text class="card-meta">区域：{{item.area}}</text>
      <text class="card-meta">发布：{{item.dateText}}</text>
      <view class="demand-foot">
        <view class="count-pill">申请 <text class="count-num">{{item.applicantCount}}</text></view>
        <view wx:if="{{item.pendingCount > 0}}" class="count-pill count-warn">待处理 <text class="count-num">{{item.pendingCount}}</text></view>
        <view wx:if="{{item.acceptedCount > 0}}" class="count-pill count-ok">已接收 <text class="count-num">{{item.acceptedCount}}</text></view>
      </view>
      <view class="card-actions">
        <button class="btn-secondary btn-sm action-btn" data-id="{{item.id}}" catchtap="showDemandDetail">详情</button>
        <button class="btn-primary btn-sm action-btn" data-id="{{item.id}}" catchtap="viewApplications">查看申请</button>
        <button wx:if="{{item.canClose}}" class="btn-sm close-btn" data-id="{{item.id}}" catchtap="closeDemand">关闭</button>
      </view>
    </view>
  </block>
  <block wx:if="{{role !== 'teacher' && activeTab === 'favorites'}}">
    <view wx:if="{{favTeachers.length === 0}}" class="empty-tip">
      <text class="empty-main">暂无收藏老师</text>
      <text class="empty-sub">查看申请时可收藏感兴趣的老师</text>
    </view>
    <view wx:for="{{favTeachers}}" wx:key="id" class="card teacher-fav-card">
      <view class="card-row card-tap" data-id="{{item.id}}" data-user-id="{{item.user_id}}" bindtap="goTeacherProfile">
        <view class="teacher-avatar">{{item.initial}}</view>
        <view class="teacher-fav-main">
          <text class="card-title">{{item.real_name}}</text>
          <text class="card-meta">{{item.teaching_subjects}}</text>
          <text wx:if="{{item.verification_status === 'verified'}}" class="badge badge-verified">已认证</text>
        </view>
        <text class="section-link">查看 ></text>
      </view>
      <button class="btn-sm unfav-btn" data-id="{{item.id}}" catchtap="unfavTeacher">取消收藏</button>
    </view>
  </block>
  <block wx:if="{{role === 'teacher' && activeTab === 'all'}}">
    <view wx:if="{{loading}}" class="empty-tip">正在加载申请记录...</view>
    <view wx:elif="{{applies.length === 0}}" class="empty-tip">
      <text class="empty-main">还没有申请过需求</text>
      <text class="empty-sub">浏览需求列表找到合适的家教机会</text>
    </view>
    <view wx:for="{{applies}}" wx:key="id" class="card apply-card card-tap" data-demand-id="{{item.demand_id}}" bindtap="goApplyDetail">
      <view class="card-row">
        <view class="demand-main">
          <text class="card-title">{{item.demandTitle}}</text>
          <text class="card-meta">{{item.demandSubject}} · {{item.demandArea}}</text>
        </view>
        <text class="badge badge-{{item.status === 'pending' ? 'applied' : item.status}} {{item.statusChanged ? 'badge-flash' : ''}}">{{item.statusText}}</text>
      </view>
      <view class="apply-foot">
        <text class="tag">{{item.demandMode}}</text>
        <text class="card-meta">申请于 {{item.dateText}}</text>
      </view>
      <text wx:if="{{item.status === 'accepted'}}" class="apply-hint accepted">已接单，等待家长联系你</text>
      <text wx:elif="{{item.status === 'rejected'}}" class="apply-hint muted">未通过，可继续申请其他需求</text>
      <text wx:else class="apply-hint">审核中，请耐心等待</text>
    </view>
  </block>
  <block wx:if="{{role === 'teacher' && activeTab === 'favorites'}}">
    <view wx:if="{{favDemands.length === 0}}" class="empty-tip">
      <text class="empty-main">暂无收藏需求</text>
      <text class="empty-sub">浏览需求时可收藏感兴趣的需求</text>
    </view>
    <view wx:for="{{favDemands}}" wx:key="id" class="card fav-demand-card">
      <view class="card-row card-tap" data-id="{{item.id}}" bindtap="goFavDemandDetail">
        <view class="demand-main">
          <text class="card-title">{{item.title}}</text>
          <text class="card-meta">{{item.subject}} · {{item.grade_level}} · {{item.area}}</text>
        </view>
        <text class="badge badge-{{item.status === 'open' ? 'open' : 'closed'}}">{{item.statusText}}</text>
      </view>
      <text class="card-meta">发布：{{item.dateText}}</text>
      <button class="btn-sm unfav-btn" data-id="{{item.id}}" catchtap="unfavDemand">取消收藏</button>
    </view>
  </block>
</view>