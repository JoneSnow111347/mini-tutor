.tab-bar {
  display: flex;
  gap: 8rpx;
  margin-bottom: 24rpx;
  padding: 8rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 142, 83, 0.1);
  background: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(45, 42, 38, 0.04);
}

.tab-item {
  flex: 1;
  height: 68rpx;
  border-radius: 14rpx;
  color: #8C857D;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 68rpx;
  text-align: center;
  transition: background 0.2s, color 0.2s;
}

.tab-item:active {
  opacity: 0.8;
}

.tab-active {
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.25);
}

.demand-main {
  flex: 1;
  min-width: 0;
}

.demand-foot {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(255, 142, 83, 0.06);
}

.count-pill {
  display: inline-flex;
  align-items: center;
  gap: 4rpx;
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #F7F6F3;
  color: #8C857D;
  font-size: 22rpx;
  line-height: 1;
}

.count-num {
  font-weight: 600;
  color: #5A5550;
}

.count-warn {
  background: #FFF8ED;
  color: #C07A10;
}

.count-warn .count-num {
  color: #C07A10;
}

.count-ok {
  background: #E8FFF5;
  color: #00875A;
}

.count-ok .count-num {
  color: #00875A;
}

.card-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 20rpx;
}

.action-btn {
  flex: 1;
}

.empty-main {
  display: block;
  color: #5A5550;
  font-size: 28rpx;
  font-weight: 600;
}

.empty-sub {
  display: block;
  margin-top: 8rpx;
  color: #9A938B;
  font-size: 24rpx;
}

.empty-cta {
  display: inline-block;
  margin-top: 24rpx;
  min-height: 64rpx;
  padding: 0 32rpx;
  font-size: 24rpx;
  line-height: 64rpx;
}

.close-btn,
.unfav-btn {
  min-height: 64rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 64rpx;
  transition: transform 0.15s;
}

.close-btn:active,
.unfav-btn:active {
  transform: scale(0.95);
}

.close-btn {
  flex: 1;
  border: 2rpx solid rgba(255, 179, 71, 0.2);
  background: linear-gradient(135deg, #FFF8ED 0%, #FFFCF5 100%);
  color: #D48A08;
}

.unfav-btn {
  width: 100%;
  margin-top: 14rpx;
  border: 2rpx solid rgba(255, 142, 83, 0.12);
  background: #FFFFFF;
  color: #8C857D;
}

.teacher-fav-card .card-row {
  align-items: center;
}

.teacher-avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 68rpx;
  text-align: center;
  flex-shrink: 0;
}

.teacher-fav-main {
  flex: 1;
  min-width: 0;
  padding: 0 14rpx;
}

.apply-card {
  cursor: pointer;
}

.apply-foot {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 16rpx;
}

.apply-hint {
  display: block;
  margin-top: 12rpx;
  color: #FF6B6B;
  font-size: 24rpx;
  font-weight: 500;
  text-align: right;
}

.apply-hint.accepted { color: #00A87A; }
.apply-hint.muted    { color: #B0A99F; }

.card-closing {
  opacity: 0.5;
}
