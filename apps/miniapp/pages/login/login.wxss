.login-page {
  padding-top: 58rpx;
}

.login-hero {
  padding: 32rpx 6rpx 42rpx;
}

.app-mark {
  width: 112rpx;
  height: 112rpx;
  margin-bottom: 30rpx;
  border-radius: 30rpx;
  background: linear-gradient(145deg, #ffffff, #e8f2ff);
  color: #007aff;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 112rpx;
  text-align: center;
  box-shadow: 0 18rpx 40rpx rgba(0, 122, 255, 0.14);
}

.login-card {
  padding: 28rpx;
}

.role-group {
  display: flex;
  gap: 12rpx;
  margin-bottom: 34rpx;
  padding: 8rpx;
  border-radius: 24rpx;
  background: #eef1f6;
}

.role-button {
  flex: 1;
  height: 78rpx;
  border-radius: 20rpx;
  background: transparent;
  color: #6b7280;
  font-size: 27rpx;
  font-weight: 750;
  line-height: 78rpx;
}

.role-active {
  background: #ffffff;
  color: #111827;
  box-shadow: 0 10rpx 24rpx rgba(31, 41, 55, 0.1);
}

.feedback {
  margin: 4rpx 2rpx 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  font-size: 25rpx;
  line-height: 1.4;
}

.feedback.error {
  background: #fff0f0;
  color: #d92d20;
}

.feedback.success {
  background: #eaf8ef;
  color: #16833a;
}

.login-button {
  margin-top: 10rpx;
}

.register-link {
  margin-top: 18rpx;
  height: 64rpx;
  background: transparent;
  color: #007aff;
  font-size: 25rpx;
  font-weight: 650;
  line-height: 64rpx;
}
