<view class="container">
  <view class="auth-header">
    <text class="auth-icon">师</text>
    <text class="auth-title">教师登录</text>
    <text class="auth-sub">使用手机号登录教师账户</text>
  </view>
  <view class="form-group">
    <text class="form-label">手机号<text class="required">*</text></text>
    <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" value="{{phone}}" bindinput="onPhoneInput" bindconfirm="handleLogin" />
  </view>
  <button class="btn-primary" loading="{{loading}}" disabled="{{loading}}" bindtap="handleLogin">{{loading ? '登录中...' : '登录'}}</button>
  <text class="link-text" bindtap="goRegister">还没有账号？立即注册</text>
</view>