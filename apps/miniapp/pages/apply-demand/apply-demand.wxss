.detail-row {
  display: flex;
  justify-content: space-between;
  margin-top: 24rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
}

.detail-key {
  color: #8C857D;
  font-size: 24rpx;
}

.detail-val {
  color: #1A1714;
  font-size: 26rpx;
  font-weight: 600;
}

.desc-block {
  display: block;
  margin-top: 18rpx;
  color: #5A5550;
  font-size: 26rpx;
  line-height: 1.6;
}

.map-btn {
  margin-top: 20rpx;
}

.banner-warning {
  background: #FFF8ED;
  color: #B8860B;
  border-color: rgba(184, 134, 11, 0.12);
}

.banner-cta {
  display: inline-block;
  margin-top: 16rpx;
  min-height: 56rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  border: 2rpx solid #E8642A;
  background: #FFFFFF;
  color: #E8642A;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 56rpx;
}

.banner-cta:active {
  background: #FFF3ED;
}
