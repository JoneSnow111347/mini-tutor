/* pages/home/home.wxss */

.home-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 80rpx 64rpx;
}

/* Hero section */
.hero {
  text-align: center;
  margin-bottom: 72rpx;
}
.hero-icon {
  display: block;
  font-size: 120rpx;
  margin-bottom: 24rpx;
}
.hero-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 16rpx;
}
.hero-sub {
  display: block;
  font-size: 28rpx;
  color: #888;
}

.btn-group { margin-bottom: 48rpx; }

/* Flex row inside each role-selection button so emoji + text align together
   and the button height grows naturally instead of clipping tall glyphs. */
.btn-inner {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;     /* falls back to two lines on very narrow screens */
  gap: 12rpx;
}
.btn-emoji {
  font-size: 36rpx;
  line-height: 1.2;
  flex-shrink: 0;      /* emoji never shrinks or disappears */
}
.btn-label {
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
}
.home-footer {
  display: block;
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
}

/* Greeting card — tappable, navigates to the full "我的" account page */
.greeting-card { margin-bottom: 48rpx; }

/* Flex row: info on left, chevron on right */
.greeting-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

/* Right-pointing chevron hint */
.greeting-arrow {
  font-size: 44rpx;
  color: #ccc;
  font-weight: 300;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.greeting-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 8rpx;
}
.greeting-role {
  display: block;
  font-size: 26rpx;
  color: #888;
}

/* Subtle press feedback on the tappable greeting card */
.greeting-card:active {
  background: #f5f7fb;
  transition: background 0.08s ease;
}

/* Menu grid */
.menu-grid {
  display: flex;
  gap: 24rpx;
  margin-bottom: 48rpx;
}
.menu-tile {
  flex: 1;
  background: #fff;
  border-radius: 16rpx;
  padding: 40rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}
.tile-icon {
  display: block;
  font-size: 72rpx;
  margin-bottom: 16rpx;
}
.tile-label {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}
.tile-desc {
  display: block;
  font-size: 22rpx;
  color: #aaa;
}

/* ── Pending-application badge ─────────────────────────────────────────────
   .badge-wrap  — gives the tile a positioning context (position:relative).
   .badge-dot   — absolute red pill in the top-right corner of the tile.
                  Min-width handles single vs. double-digit counts cleanly.
   ──────────────────────────────────────────────────────────────────────── */
.badge-wrap {
  position: relative;
}
.badge-dot {
  position: absolute;
  top: -14rpx;
  right: -14rpx;
  min-width: 44rpx;
  height: 44rpx;
  padding: 0 10rpx;
  border-radius: 22rpx;
  background: #e74c3c;
  color: #fff;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 44rpx;
  text-align: center;
  box-sizing: border-box;
  z-index: 10;
  /* Pop-in animation when badge first renders or count updates */
  animation: badge-pulse 0.35s ease both;
}

/* Subtle press feedback on menu tiles */
.menu-tile:active {
  background: #f0f4ff;
  transform: scale(0.97);
  transition: transform 0.1s ease, background 0.1s ease;
}

/* ── Recent notification list ────────────────────────────────────────────────
   Shown in the teacher dashboard below the menu-grid.
   Each item uses a left accent border to communicate accepted (green) vs
   rejected (red) at a glance.  Unread items have a small red dot on the right.
   ──────────────────────────────────────────────────────────────────────────── */
.notif-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 1rpx 8rpx rgba(0, 0, 0, 0.05);
  position: relative;
  /* Slide in when list first renders */
  animation: slide-down 0.25s ease both;
}

/* Left accent: green = accepted, red = rejected */
.notif-accepted { border-left: 6rpx solid #27ae60; }
.notif-rejected { border-left: 6rpx solid #e53935; }

/* Read notifications are visually de-emphasised */
.notif-read { opacity: 0.6; }

.notif-icon {
  font-size: 40rpx;
  line-height: 1;
  flex-shrink: 0;
}

.notif-body { flex: 1; overflow: hidden; }

.notif-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
  /* Single-line truncation */
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
}

.notif-status {
  display: block;
  font-size: 24rpx;
  color: #888;
}

/* Small red dot on the far right for unread items */
.notif-unread-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #e74c3c;
  flex-shrink: 0;
  animation: badge-pulse 0.35s ease both;
}
