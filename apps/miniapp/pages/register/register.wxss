.register-page {
  padding-top: 42rpx;
}

.register-hero {
  padding: 28rpx 6rpx 34rpx;
}

.app-mark {
  width: 104rpx;
  height: 104rpx;
  margin-bottom: 26rpx;
  border-radius: 30rpx;
  background: linear-gradient(145deg, #ffffff, #e8f2ff);
  color: #007aff;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 104rpx;
  text-align: center;
  box-shadow: 0 18rpx 40rpx rgba(0, 122, 255, 0.14);
}

.register-card {
  padding: 28rpx;
}

.role-group {
  display: flex;
  gap: 12rpx;
  padding: 8rpx;
  border-radius: 24rpx;
  background: #eef1f6;
}

.role-button {
  flex: 1;
  min-height: 78rpx;
  height: auto;
  padding: 0 12rpx;
  border-radius: 20rpx;
  background: transparent;
  color: #6b7280;
  font-size: 25rpx;
  font-weight: 750;
  line-height: 78rpx;
}

.switch-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin: 4rpx 0 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: #f5f7fb;
}

.switch-title {
  display: block;
  color: #111827;
  font-size: 27rpx;
  font-weight: 750;
}

.switch-sub {
  display: block;
  margin-top: 6rpx;
  color: #8a94a6;
  font-size: 23rpx;
}

.role-active {
  background: #ffffff;
  color: #111827;
  box-shadow: 0 10rpx 24rpx rgba(31, 41, 55, 0.1);
}

.feedback {
  margin: 4rpx 2rpx 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  font-size: 25rpx;
  line-height: 1.4;
}

.feedback.error {
  background: #fff0f0;
  color: #d92d20;
}

.feedback.success {
  background: #eaf8ef;
  color: #16833a;
}

.register-button {
  margin-top: 8rpx;
}

.login-link {
  margin-top: 18rpx;
  height: 64rpx;
  background: transparent;
  color: #007aff;
  font-size: 25rpx;
  font-weight: 650;
  line-height: 64rpx;
}
