.register-page {
  position: relative;
  overflow: hidden;
  padding: 40rpx 28rpx 56rpx;
  background: #F7F6F3;
}

.register-hero {
  position: relative;
  z-index: 1;
  padding: 8rpx 8rpx 28rpx;
}

.hero-badge {
  display: inline-block;
  min-height: 52rpx;
  margin-bottom: 24rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #FFFFFF;
  color: #E8642A;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 52rpx;
}

.hero-brand {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.app-mark {
  width: 112rpx;
  height: 112rpx;
  margin: 0;
  border: 0;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  font-size: 46rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 107, 0.2);
}

.hero-copy {
  flex: 1;
  padding-top: 4rpx;
}

.title {
  margin-top: 0;
  font-size: 46rpx;
  line-height: 1.24;
  letter-spacing: 1rpx;
  color: #1A1714;
}

.subtitle {
  margin-top: 14rpx;
  color: #8C857D;
  font-size: 26rpx;
  line-height: 1.7;
}

.register-card {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  padding: 36rpx 28rpx 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 26rpx;
}

.card-title {
  display: block;
  color: #1A1714;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.3;
}

.card-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #A09890;
  font-size: 24rpx;
  line-height: 1.6;
}

.card-chip {
  min-width: 132rpx;
  min-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #FFF3ED;
  color: #E8642A;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 52rpx;
  text-align: center;
}

.section-divider {
  margin: 8rpx 0 18rpx;
  color: #A09890;
  font-size: 24rpx;
  font-weight: 500;
  letter-spacing: 2rpx;
}

.input-shell {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  padding: 0 24rpx;
  border: 2rpx solid #E8E5E0;
  border-radius: 22rpx;
  background: #FAFAF8;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.input-prefix {
  flex-shrink: 0;
  margin-right: 18rpx;
  color: #9A938B;
  font-size: 24rpx;
  font-weight: 600;
}

.register-input {
  height: 96rpx;
  padding: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
}

.code-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.code-shell {
  flex: 1;
}

.code-input {
  flex: 1;
}

.code-button {
  width: 220rpx;
  min-height: 96rpx;
  border-radius: 22rpx;
  border: 2rpx solid #E8E5E0;
  background: #FFFFFF;
  color: #FF6B6B;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 96rpx;
  transition: transform 0.15s;
}

.code-button:active {
  transform: scale(0.96);
}

.role-group {
  display: flex;
  gap: 14rpx;
}

.role-button {
  display: flex;
  flex: 1;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-height: 108rpx;
  padding: 0 22rpx;
  border: 2rpx solid #E8E5E0;
  border-radius: 28rpx;
  background: #FAFAF8;
  color: #8C857D;
  transition: transform 0.15s, border-color 0.2s;
}

.role-button:active {
  transform: scale(0.97);
}

.role-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  border-radius: 14rpx;
  background: #E8E5E0;
  color: #8C857D;
  font-size: 26rpx;
  font-weight: 700;
  transition: background 0.2s, color 0.2s;
}

.role-active .role-mark {
  background: #FF6B6B;
  color: #ffffff;
}

.role-title {
  color: inherit;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.4;
}

.role-active {
  border-color: #FF6B6B;
  background: #FFF5F2;
  color: #1A1714;
}

.role-tip {
  display: block;
  margin-top: 14rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #FAFAF8;
  color: #8C857D;
  font-size: 24rpx;
  line-height: 1.6;
}

.feedback {
  margin: 8rpx 0 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  line-height: 1.6;
}

.feedback.error {
  background: #FFF0F0;
  color: #CF1322;
}

.feedback.success {
  background: #E8FFF5;
  color: #00A87A;
}

.register-button {
  min-height: 92rpx;
  margin-top: 12rpx;
  border-radius: 22rpx;
  border: 0;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  line-height: 92rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 107, 0.2);
}

.register-button:active {
  transform: scale(0.96);
  opacity: 0.9;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.15);
}

.register-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 24rpx;
}

.footer-tip {
  color: #A09890;
  font-size: 24rpx;
}

.login-link {
  height: 56rpx;
  background: transparent;
  color: #FF6B6B;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 56rpx;
}
