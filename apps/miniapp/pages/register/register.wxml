<view class="page register-page">
  <view class="register-hero">
    <view class="app-mark">武</view>
    <text class="title">创建账号</text>
    <text class="subtitle">统一注册家长、学生和教师账号。注册成功后可直接登录，也可以返回登录页。</text>
  </view>

  <view class="card register-card">
    <view class="form-group">
      <text class="form-label">手机号<text class="required">*</text></text>
      <input class="form-input" type="number" maxlength="11" placeholder="请输入手机号" placeholder-class="placeholder" value="{{phone}}" bindinput="onPhoneInput" />
    </view>

    <view class="form-group">
      <text class="form-label">密码<text class="required">*</text></text>
      <input class="form-input" password maxlength="24" placeholder="至少 6 位" placeholder-class="placeholder" value="{{password}}" bindinput="onPasswordInput" />
    </view>

    <view class="form-group">
      <text class="form-label">身份选择<text class="required">*</text></text>
      <view class="role-group">
        <button class="role-button {{role === 'parent' || role === 'student' ? 'role-active' : ''}}" data-role="parent" bindtap="selectRole">家长/学生</button>
        <button class="role-button {{role === 'teacher' ? 'role-active' : ''}}" data-role="teacher" bindtap="selectRole">教师</button>
      </view>
    </view>

    <view class="switch-line">
      <view>
        <text class="switch-title">注册后直接登录</text>
        <text class="switch-sub">关闭后将返回登录页</text>
      </view>
      <switch checked="{{autoLogin}}" color="#34c759" bindchange="onAutoLoginChange" />
    </view>

    <view wx:if="{{message}}" class="feedback {{feedbackType}}">
      <text>{{message}}</text>
    </view>

    <button class="btn-primary register-button" loading="{{loading}}" disabled="{{loading}}" bindtap="handleRegister">
      {{loading ? '注册中...' : '注册'}}
    </button>

    <button class="login-link" bindtap="goLogin">已有账号？点击登录</button>
  </view>
</view>