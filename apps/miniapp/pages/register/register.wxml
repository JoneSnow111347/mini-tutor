<view class="page register-page">
  <view class="register-hero">
    <view class="hero-badge">新用户注册</view>
    <view class="hero-brand">
      <view class="app-mark">家</view>
      <view class="hero-copy">
        <text class="title">注册</text>
        <text class="subtitle">手机号注册，选身份即可使用</text>
      </view>
    </view>
  </view>

  <view class="card register-card">
    <view class="card-head">
      <view>
        <text class="card-title">注册</text>
        <text class="card-subtitle">注册后自动登录</text>
      </view>
      <view class="card-chip">{{role === 'teacher' ? '教师注册' : '家长注册'}}</view>
    </view>

    <view class="section-divider">账号信息</view>

    <view class="form-group">
      <text class="form-label">手机号<text class="required">*</text></text>
      <view class="input-shell">
        <text class="input-prefix">+86</text>
        <input class="form-input register-input" type="number" maxlength="11" placeholder="请输入手机号" placeholder-class="placeholder" value="{{phone}}" bindinput="onPhoneInput" />
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">设置密码<text class="required">*</text></text>
      <view class="input-shell">
        <text class="input-prefix">•••</text>
        <input class="form-input register-input" password maxlength="24" placeholder="请输入至少 6 位密码" placeholder-class="placeholder" value="{{password}}" bindinput="onPasswordInput" />
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">确认密码<text class="required">*</text></text>
      <view class="input-shell">
        <text class="input-prefix">•••</text>
        <input class="form-input register-input" password maxlength="24" placeholder="请再次输入密码" placeholder-class="placeholder" value="{{confirmPassword}}" bindinput="onConfirmPasswordInput" />
      </view>
    </view>

    <view class="section-divider">身份验证</view>

    <view class="form-group">
      <text class="form-label">短信验证码<text class="required">*</text></text>
      <view class="code-row">
        <view class="input-shell code-shell">
          <text class="input-prefix">验证码</text>
          <input class="form-input register-input code-input" type="number" maxlength="6" placeholder="输入 6 位验证码" placeholder-class="placeholder" value="{{smsCode}}" bindinput="onCodeInput" />
        </view>
        <button class="code-button" disabled="{{sendingCode || sendCooldown > 0}}" bindtap="handleSendCode">
          {{sendCooldown > 0 ? sendCooldown + 's' : '获取验证码'}}
        </button>
      </view>
    </view>

    <view class="form-group">
      <text class="form-label">身份选择<text class="required">*</text></text>
      <view class="role-group">
        <button class="role-button {{role === 'parent' ? 'role-active' : ''}}" data-role="parent" bindtap="selectRole">
          <text class="role-mark">家</text>
          <text class="role-title">我是家长</text>
        </button>
        <button class="role-button {{role === 'teacher' ? 'role-active' : ''}}" data-role="teacher" bindtap="selectRole">
          <text class="role-mark">师</text>
          <text class="role-title">我是老师</text>
        </button>
      </view>
      <text wx:if="{{role === 'teacher'}}" class="role-tip">注册后需完善资料并提交认证。</text>
    </view>

    <view wx:if="{{message}}" class="feedback {{feedbackType}}">
      <text>{{message}}</text>
    </view>

    <button class="btn-primary register-button" loading="{{loading}}" disabled="{{loading}}" bindtap="handleRegister">
      {{loading ? '注册中...' : '完成注册'}}
    </button>

    <view class="register-footer">
      <text class="footer-tip">已经有账号？</text>
      <button class="login-link" bindtap="goLogin">去登录</button>
    </view>
  </view>
</view>
