<view class="container">
  <view wx:if="{{loading}}" class="empty-tip">正在加载申请详情...</view>

  <block wx:elif="{{apply}}">
    <view wx:if="{{demand}}" class="card">
      <text class="card-title">{{demand.title}}</text>
      <text class="card-meta">{{demand.subject}} · {{demand.grade_level}} · {{demand.area}}</text>
    </view>

    <view class="card teacher-card card-tap" bindtap="goTeacherProfile">
      <view class="teacher-top">
        <view class="avatar">
          <text>{{teacherInitial}}</text>
        </view>
        <view class="teacher-main">
          <text class="teacher-name">{{teacher ? teacher.real_name : teacherFallback + apply.teacher_user_id}}</text>
          <text wx:if="{{teacher}}" class="teacher-subjects">{{teacher.teaching_subjects}}</text>
          <view class="badge-row">
            <text wx:if="{{teacher && teacher.verification_status === 'verified'}}" class="badge badge-verified">已认证</text>
            <text class="badge badge-{{apply.status}}">{{apply.statusText}}</text>
          </view>
        </view>
      </view>

      <view class="info-row">
        <text class="info-key">申请于</text>
        <text class="info-val">{{apply.dateText}}</text>
      </view>

      <view wx:if="{{apply.message}}" class="message-box">
        <text class="message-text">{{apply.message}}</text>
      </view>
      <text wx:if="{{teacher}}" class="profile-hint">查看完整资料 ></text>
    </view>

    <view wx:if="{{apply.status === 'pending'}}" class="decision-actions">
      <button class="btn-danger decision-reject" disabled="{{submitting}}" loading="{{submitting}}" bindtap="confirmReject">{{submitting ? '处理中...' : '拒绝'}}</button>
      <button class="btn-success decision-accept" disabled="{{submitting}}" loading="{{submitting}}" bindtap="confirmAccept">{{submitting ? '处理中...' : '接受申请'}}</button>
    </view>

    <view wx:else class="status-banner {{apply.status === 'accepted' ? 'banner-success' : 'banner-danger'}}">
      <text class="status-banner-title">{{apply.status === 'accepted' ? '已接受该申请' : '已拒绝该申请'}}</text>
      <text class="status-banner-sub">{{apply.status === 'accepted' ? '老师已获得你的联系方式' : '该老师无法继续申请此需求'}}</text>
    </view>
  </block>
</view>
