<view class="container">
  <view class="ios-hero">
    <text class="eyebrow">教师资料</text>
    <text class="title">{{hasProfile ? '编辑资料' : '完善资料'}}</text>
    <text class="subtitle">资料将展示给家长，请填写真实姓名、科目和联系方式。</text>
  </view>
  <view wx:if="{{loading}}" class="empty-tip">正在加载资料...</view>
  <block wx:else>
    <view class="card edit-card">
      <view class="form-group"><text class="form-label">姓名<text class="required">*</text></text><input class="form-input" type="text" maxlength="20" value="{{real_name}}" bindinput="onNameInput" placeholder="请输入姓名" placeholder-class="placeholder" /></view>
      <view class="form-group"><text class="form-label">科目<text class="required">*</text></text><input class="form-input" type="text" value="{{teaching_subjects}}" bindinput="onSubjectsInput" placeholder="多个科目用逗号分隔" placeholder-class="placeholder" /><text class="form-hint">例：数学,物理,英语</text></view>
      <view class="form-group"><text class="form-label">手机号<text class="required">*</text></text><input class="form-input" type="number" maxlength="11" value="{{phone}}" bindinput="onPhoneInput" placeholder="请输入手机号" placeholder-class="placeholder" /><text class="form-hint">当前后端手机号属于登录账号，此处用于资料展示校验。</text></view>
      <view class="form-group"><text class="form-label">认证状态</text><view class="verify-row"><button wx:for="{{verificationOptions}}" wx:key="value" class="verify-button {{verification_status === item.value ? 'verify-active' : ''}}" data-status="{{item.value}}" bindtap="selectVerification">{{item.label}}</button></view></view>
      <view class="form-group"><text class="form-label">简介</text><textarea class="form-textarea" maxlength="300" value="{{bio}}" bindinput="onBioInput" placeholder="介绍教学经验、授课风格和可辅导年级" placeholder-class="placeholder" /><text class="char-count">{{bio.length}} / 300</text></view>
      <view class="switch-row"><view><text class="form-label switch-label">公开资料</text><text class="form-hint">开启后家长可查看你的教师资料</text></view><switch checked="{{is_public}}" bindchange="onPublicChange" color="#34c759" /></view>
    </view>
    <button class="btn-primary" disabled="{{submitting}}" loading="{{submitting}}" bindtap="saveProfile">{{submitting ? '保存中...' : '保存资料'}}</button>
  </block>
  <button class="global-logout-btn" bindtap="handleGlobalLogout">退出登录</button>
</view>