.edit-card {
  padding-bottom: 8rpx;
}

.status-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid rgba(255, 142, 83, 0.08);
}

.status-label {
  display: block;
  color: #8C857D;
  font-size: 24rpx;
}

.status-value {
  display: block;
  margin-top: 6rpx;
  color: #1A1714;
  font-size: 32rpx;
  font-weight: 600;
}

.status-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 500;
  color: #8C857D;
  background: #F5F2EF;
}

.status-unverified {
  background: #F5F2EF;
  color: #8C857D;
}

.status-pending {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFF8ED 100%);
  color: #E6A817;
}

.status-approved {
  background: linear-gradient(135deg, #E8FFF5 0%, #F0FFF8 100%);
  color: #00A87A;
}

.status-rejected {
  background: linear-gradient(135deg, #FFF0F0 0%, #FFF5F5 100%);
  color: #CF1322;
}

.status-tip {
  display: block;
  margin-bottom: 24rpx;
  color: #9A938B;
  font-size: 24rpx;
  line-height: 1.5;
}

.proof-card {
  margin-top: 20rpx;
}

.proof-title {
  display: block;
  color: #1A1714;
  font-size: 32rpx;
  font-weight: 600;
}

.proof-subtitle {
  display: block;
  margin-top: 8rpx;
  color: #8C857D;
  font-size: 24rpx;
  line-height: 1.5;
}

.type-grid {
  display: flex;
  gap: 10rpx;
  margin: 18rpx 0 16rpx;
}

.type-btn {
  flex: 1;
  min-height: 72rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(255, 142, 83, 0.12);
  background: #FFFFFF;
  color: #8C857D;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 72rpx;
  transition: transform 0.15s;
}

.type-btn:active {
  transform: scale(0.96);
}

.type-btn-active {
  border-color: transparent;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.25);
}

.upload-box {
  margin-bottom: 16rpx;
  padding: 28rpx 20rpx;
  border: 2rpx dashed rgba(255, 142, 83, 0.25);
  border-radius: 18rpx;
  background: linear-gradient(135deg, #FFFCF8 0%, #FFF8F0 100%);
  transition: border-color 0.2s;
}

.upload-box:active {
  border-color: #FF8E53;
}

.upload-title {
  display: block;
  color: #2D2A26;
  font-size: 28rpx;
  font-weight: 500;
}

.upload-sub {
  display: block;
  margin-top: 8rpx;
  color: #9A938B;
  font-size: 24rpx;
}

.proof-button {
  margin-top: 6rpx;
}

.proof-record {
  margin-top: 24rpx;
}

.profile-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(255, 142, 83, 0.06);
}

.prow-key {
  color: #8C857D;
  font-size: 24rpx;
  font-weight: 500;
}

.prow-val {
  color: #1A1714;
  font-size: 28rpx;
  font-weight: 600;
}

.note-box {
  margin: 16rpx 0 12rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFF8ED 100%);
  border: 1rpx solid rgba(230, 168, 23, 0.1);
}

.note-title {
  display: block;
  color: #E6A817;
  font-size: 24rpx;
  font-weight: 500;
}

.note-content {
  display: block;
  margin-top: 6rpx;
  color: #8C6A00;
  font-size: 24rpx;
  line-height: 1.5;
}

.preview-button {
  margin-top: 12rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 10rpx 0 20rpx;
}

.switch-label {
  margin-bottom: 0;
}
