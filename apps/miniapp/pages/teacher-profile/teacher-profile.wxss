.profile-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 142, 83, 0.1);
  background: linear-gradient(180deg, #FFFFFF 0%, #FFFCF8 100%);
  box-shadow: 0 8rpx 28rpx rgba(45, 42, 38, 0.06);
}

.profile-hero {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.profile-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  text-align: center;
  box-shadow: 0 8rpx 20rpx rgba(255, 107, 107, 0.28);
}

.profile-avatar-text {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 96rpx;
}

.profile-hero-info {
  flex: 1;
  min-width: 0;
}

.profile-name {
  display: block;
  color: #1A1714;
  font-size: 36rpx;
  font-weight: 700;
}

.summary-grid {
  display: flex;
  gap: 12rpx;
  margin-top: 24rpx;
}

.summary-item {
  flex: 1;
  padding: 18rpx 12rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #FFF8F0 0%, #FFFCF8 100%);
  text-align: center;
}

.summary-value {
  display: block;
  color: #1A1714;
  font-size: 28rpx;
  font-weight: 600;
}

.summary-label {
  display: block;
  margin-top: 6rpx;
  color: #8C857D;
  font-size: 24rpx;
}

.profile-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(255, 142, 83, 0.06);
}

.profile-row.last {
  border-bottom: 0;
}

.prow-key {
  flex-shrink: 0;
  color: #8C857D;
  font-size: 24rpx;
}

.prow-val {
  max-width: 66%;
  color: #1A1714;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.5;
  text-align: right;
}

.edit-card {
  padding-bottom: 4rpx;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 16rpx 0 20rpx;
}

.switch-label {
  margin-bottom: 0;
}

.cancel-button {
  margin-top: 18rpx;
}

.empty-card {
  margin-top: 96rpx;
  padding: 36rpx 24rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 142, 83, 0.1);
  background: #FFFFFF;
  text-align: center;
  box-shadow: 0 6rpx 20rpx rgba(45, 42, 38, 0.04);
}

.empty-title {
  display: block;
  color: #1A1714;
  font-size: 32rpx;
  font-weight: 600;
}

.empty-sub {
  display: block;
  margin: 12rpx 0 28rpx;
  color: #8C857D;
  font-size: 28rpx;
  line-height: 1.5;
}
