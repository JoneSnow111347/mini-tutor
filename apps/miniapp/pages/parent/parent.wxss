.dashboard-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 8rpx 0 24rpx;
}

.notify-button {
  position: relative;
  width: 72rpx;
  height: 72rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 142, 83, 0.15);
  background: linear-gradient(135deg, #FFF8F0 0%, #FFFFFF 100%);
  box-shadow: 0 4rpx 12rpx rgba(45, 42, 38, 0.06);
  transition: transform 0.15s;
}

.notify-button:active {
  transform: scale(0.92);
}

.notify-icon {
  display: block;
  color: #FF6B6B;
  font-size: 26rpx;
  font-weight: 600;
  line-height: 72rpx;
  text-align: center;
}

.notification-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  border: 4rpx solid #FFF8F0;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 36rpx;
  text-align: center;
}

.summary-card {
  display: flex;
  align-items: center;
  min-height: 140rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 142, 83, 0.1);
  background: linear-gradient(135deg, #FFFFFF 0%, #FFFCF8 100%);
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(45, 42, 38, 0.06);
}

.summary-item {
  flex: 1;
  padding: 24rpx 8rpx;
  text-align: center;
}

.summary-value {
  display: block;
  color: #1A1714;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.2;
}

.summary-label {
  display: block;
  margin-top: 6rpx;
  color: #8C857D;
  font-size: 24rpx;
}

.summary-divider {
  width: 1rpx;
  height: 56rpx;
  background: rgba(255, 142, 83, 0.1);
}

.warn {
  color: #E6A817;
}

.ok {
  color: #00A87A;
}

.action-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 20rpx;
}

.action-card {
  position: relative;
  min-height: 136rpx;
  padding: 26rpx 22rpx;
  border-radius: 24rpx;
  border: 1rpx solid rgba(255, 142, 83, 0.1);
  background: #FFFFFF;
  color: #2D2A26;
  text-align: left;
  box-shadow: 0 4rpx 16rpx rgba(45, 42, 38, 0.04);
  transition: transform 0.15s, box-shadow 0.15s;
}

.action-card:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(45, 42, 38, 0.06);
}

.primary-action {
  border-color: rgba(255, 107, 107, 0.2);
  background: linear-gradient(135deg, #FFF8F0 0%, #FFF0E6 100%);
}

.action-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
  color: #1A1714;
}

.action-desc {
  display: block;
  margin-top: 8rpx;
  color: #8C857D;
  font-size: 24rpx;
  line-height: 1.5;
}

.dot-badge {
  position: absolute;
  top: 18rpx;
  right: 18rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
}

.demand-main {
  flex: 1;
  min-width: 0;
}

.demand-foot {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 142, 83, 0.08);
  color: #8C857D;
  font-size: 24rpx;
}

.demand-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 16rpx;
}

.fav-btn,
.close-button,
.detail-button {
  flex: 1;
  min-height: 64rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 64rpx;
  transition: transform 0.15s;
}

.fav-btn:active,
.close-button:active,
.detail-button:active {
  transform: scale(0.95);
}

.fav-btn {
  border: 2rpx solid rgba(255, 142, 83, 0.15);
  background: #FFFFFF;
  color: #8C857D;
}

.fav-active {
  border-color: rgba(255, 107, 107, 0.3);
  background: linear-gradient(135deg, #FFF0E6 0%, #FFF5EE 100%);
  color: #FF6B6B;
}

.close-button {
  border: 2rpx solid rgba(255, 179, 71, 0.2);
  background: linear-gradient(135deg, #FFF8ED 0%, #FFFCF5 100%);
  color: #D48A08;
}

.detail-button {
  border: 2rpx solid rgba(255, 107, 107, 0.2);
  background: linear-gradient(135deg, #FFF8F0 0%, #FFFCF8 100%);
  color: #FF6B6B;
}

.card-closing {
  opacity: 0.5;
}
