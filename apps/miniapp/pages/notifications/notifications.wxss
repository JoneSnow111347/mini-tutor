.notif-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 8rpx 0 24rpx;
}

.unread-pill {
  flex-shrink: 0;
  height: 44rpx;
  padding: 0 16rpx;
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FFF0E6 0%, #FFF5EE 100%);
  color: #E8642A;
  font-size: 22rpx;
  font-weight: 500;
  line-height: 44rpx;
  text-align: center;
}

.read-link {
  display: block;
  margin-bottom: 20rpx;
  color: #FF6B6B;
  font-size: 24rpx;
  font-weight: 500;
  text-align: right;
}

.empty-main {
  display: block;
  color: #5A5550;
  font-size: 28rpx;
  font-weight: 600;
}

.empty-sub {
  display: block;
  margin-top: 8rpx;
  color: #9A938B;
  font-size: 24rpx;
}

.notif-card {
  position: relative;
  overflow: visible;
}

.notif-unread {
  border-left: 6rpx solid #FF6B6B;
}

.notif-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.notif-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-accepted {
  background: linear-gradient(135deg, #E8FFF5 0%, #F0FFF8 100%);
}

.icon-rejected {
  background: linear-gradient(135deg, #FFF0F0 0%, #FFF5F5 100%);
}

.icon-pending {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFF8ED 100%);
}

.notif-icon {
  font-size: 28rpx;
  font-weight: 700;
  color: #2D2A26;
}

.icon-accepted .notif-icon { color: #00A87A; }
.icon-rejected .notif-icon { color: #CF1322; }
.icon-pending  .notif-icon { color: #E6A817; }

.notif-main {
  flex: 1;
  min-width: 0;
}

.notif-title {
  display: block;
  color: #1A1714;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.4;
}

.notif-body {
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
  margin-top: 6rpx;
  color: #8C857D;
  font-size: 24rpx;
  line-height: 1.5;
}

.notif-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  flex-shrink: 0;
}

.notif-time {
  color: #B0A99F;
  font-size: 22rpx;
}

.unread-dot {
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
}
