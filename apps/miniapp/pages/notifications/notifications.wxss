.notif-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 4rpx 28rpx;
}

.unread-pill {
  flex-shrink: 0;
  height: 52rpx;
  padding: 0 20rpx;
  margin-top: 36rpx;
  border-radius: 999rpx;
  background: #ff3b30;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 52rpx;
  text-align: center;
}

.read-button {
  margin-bottom: 22rpx;
  height: 70rpx;
  border-radius: 22rpx;
  background: #ffffff;
  color: #007aff;
  font-size: 25rpx;
  font-weight: 750;
  line-height: 70rpx;
  box-shadow: 0 12rpx 28rpx rgba(31, 41, 55, 0.08);
}

@keyframes badge-flash-anim {
  0%   { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 59, 48, 0.5); }
  25%  { transform: scale(1.2); box-shadow: 0 0 0 12rpx rgba(255, 59, 48, 0.2); }
  50%  { transform: scale(0.95); box-shadow: 0 0 0 6rpx rgba(255, 59, 48, 0.08); }
  75%  { transform: scale(1.1); }
  100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(255, 59, 48, 0); }
}

.badge-flash-anim {
  animation: badge-flash-anim 0.8s ease both;
}

.notif-card {
  position: relative;
  overflow: visible;
}

.notif-flash {
  animation: notif-slide-pulse 0.8s ease both;
}

@keyframes notif-slide-pulse {
  0% { opacity: 0.55; transform: translateY(-18rpx) scale(0.98); }
  45% { opacity: 1; transform: translateY(0) scale(1.015); }
  100% { opacity: 1; transform: translateY(0) scale(1); }
}

.notif-unread {
  border-left: 6rpx solid #007aff;
}

.notif-row {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.notif-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-accepted { background: #eaf8ef; }
.icon-rejected { background: #fff0f0; }
.icon-pending  { background: #fff7e6; }

.notif-icon {
  font-size: 30rpx;
  font-weight: 900;
  color: #111827;
}

.icon-accepted .notif-icon { color: #16833a; }
.icon-rejected .notif-icon { color: #d92d20; }
.icon-pending  .notif-icon { color: #b76e00; }

.notif-main {
  flex: 1;
  min-width: 0;
}

.notif-title {
  display: block;
  color: #111827;
  font-size: 28rpx;
  font-weight: 750;
  line-height: 1.3;
}

.notif-body {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.notif-right {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  flex-shrink: 0;
}

.notif-time {
  color: #9ca3af;
  font-size: 22rpx;
}

.unread-dot {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #007aff;
  animation: badge-pop 0.32s ease both, pulse 1.8s ease-in-out infinite 0.35s;
}
