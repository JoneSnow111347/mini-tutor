.search-card,
.teacher-entry {
  margin-bottom: 20rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  background: #FFFFFF;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.teacher-entry-inner {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.teacher-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 72rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.2);
}

.teacher-entry-main {
  flex: 1;
  min-width: 0;
}

.teacher-entry-name {
  display: block;
  color: #1A1714;
  font-size: 28rpx;
  font-weight: 600;
}

.teacher-entry-sub {
  display: block;
  margin-top: 6rpx;
  color: #8C857D;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.teacher-entry-link {
  color: #FF6B6B;
  font-size: 24rpx;
  font-weight: 500;
}

.fav-btn-sm,
.fav-btn {
  margin-top: 14rpx;
  width: 100%;
  min-height: 62rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E8E5E0;
  background: #FFFFFF;
  color: #8C857D;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 62rpx;
  transition: transform 0.15s;
}

.fav-btn-sm:active,
.fav-btn:active {
  transform: scale(0.97);
}

.fav-sm-active,
.fav-active {
  border-color: rgba(255, 107, 107, 0.3);
  background: #FFF3ED;
  color: #FF6B6B;
}

.search-bar {
  display: flex;
  align-items: center;
  height: 84rpx;
  margin-bottom: 16rpx;
  padding: 0 20rpx;
  border: 2rpx solid #E8E5E0;
  border-radius: 20rpx;
  background: #FAFAF8;
}

.search-input {
  flex: 1;
  height: 84rpx;
  font-size: 27rpx;
}

.search-clear {
  color: #FF6B6B;
  font-size: 24rpx;
  font-weight: 500;
}

.filter-scroll {
  width: 100%;
  margin-top: 12rpx;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 12rpx;
}

.filter-chip {
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 2rpx solid #E8E5E0;
  background: #FFFFFF;
  color: #8C857D;
  font-size: 24rpx;
  line-height: 56rpx;
  transition: transform 0.15s;
}

.filter-chip:active {
  transform: scale(0.95);
}

.filter-active {
  border-color: transparent;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.2);
}

.demand-main {
  flex: 1;
  min-width: 0;
}

.badge-stack {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8rpx;
}

.desc {
  display: block;
  margin-top: 16rpx;
  color: #8C857D;
  font-size: 28rpx;
  line-height: 1.6;
}

.apply-hint {
  color: #FF6B6B;
  font-size: 24rpx;
  font-weight: 500;
}

.apply-hint.accepted { color: #00A87A; }
.apply-hint.pending  { color: #E6A817; }
.apply-hint.muted    { color: #9A938B; }

.action-row {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.map-link {
  color: #FF6B6B;
  font-size: 24rpx;
  font-weight: 500;
}

.card-leaving,
.card-updated {
  opacity: 0.72;
}
