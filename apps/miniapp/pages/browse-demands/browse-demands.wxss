.search-card {
  margin-bottom: 24rpx;
  padding: 22rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 46rpx rgba(31, 41, 55, 0.08);
}

.teacher-entry {
  margin-bottom: 22rpx;
  padding: 22rpx;
  border-radius: 30rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 46rpx rgba(31, 41, 55, 0.08);
}

.teacher-entry-inner {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.teacher-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #007aff, #34c8ff);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 76rpx;
  text-align: center;
}

.teacher-entry-main {
  flex: 1;
  min-width: 0;
}

.teacher-entry-name {
  display: block;
  color: #111827;
  font-size: 29rpx;
  font-weight: 800;
}

.teacher-entry-sub {
  display: block;
  margin-top: 6rpx;
  color: #6b7280;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.teacher-entry-link {
  color: #007aff;
  font-size: 24rpx;
  font-weight: 700;
}

.fav-btn-sm {
  margin-top: 14rpx;
  width: 100%;
  min-height: 62rpx;
  border-radius: 18rpx;
  background: #fff7f0;
  color: #c2410c;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 62rpx;
}

.fav-sm-active {
  background: #ff3b30;
  color: #ffffff;
}

.search-bar {
  display: flex;
  align-items: center;
  height: 82rpx;
  margin-bottom: 18rpx;
  padding: 0 22rpx;
  border-radius: 24rpx;
  background: #f3f6fa;
}

.search-input {
  flex: 1;
  height: 82rpx;
  font-size: 27rpx;
}

.search-clear {
  color: #007aff;
  font-size: 24rpx;
  font-weight: 700;
}

.filter-scroll {
  width: 100%;
  margin-top: 12rpx;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 12rpx;
}

.filter-chip {
  height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #f0f3f7;
  color: #5d6675;
  font-size: 24rpx;
  font-weight: 650;
  line-height: 58rpx;
}

.filter-active {
  background: #111827;
  color: #ffffff;
}

.demand-main {
  flex: 1;
  min-width: 0;
}

.badge-stack {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 8rpx;
}

.desc {
  display: block;
  margin-top: 18rpx;
  color: #4b5563;
  font-size: 25rpx;
  line-height: 1.5;
}

.apply-hint {
  display: block;
  margin-top: 18rpx;
  color: #007aff;
  font-size: 26rpx;
  font-weight: 700;
  text-align: right;
}

.apply-hint.accepted { color: #16833a; }
.apply-hint.pending  { color: #b76e00; }
.apply-hint.muted    { color: #9ca3af; }

/* Favorite button on demand card */
.fav-btn {
  margin-top: 16rpx;
  width: 100%;
  min-height: 62rpx;
  border-radius: 18rpx;
  background: #fff7f0;
  color: #c2410c;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 62rpx;
}

.fav-active {
  background: #ff3b30;
  color: #ffffff;
}

@keyframes badge-flash {
  0% { transform: scale(1); }
  25% { transform: scale(1.28); box-shadow: 0 0 0 10rpx rgba(0, 122, 255, 0.16); }
  55% { transform: scale(0.94); }
  100% { transform: scale(1); }
}

.badge-flash {
  animation: badge-flash 0.75s ease both;
}

@keyframes card-leave {
  from { opacity: 1; transform: translateY(0) scale(1); }
  to { opacity: 0; transform: translateY(-18rpx) scale(0.96); }
}

.card-leaving {
  animation: card-leave 0.3s ease forwards;
  pointer-events: none;
}

@keyframes card-update {
  0% { opacity: 0.88; transform: translateY(12rpx); }
  45% { opacity: 1; transform: translateY(0); box-shadow: 0 22rpx 52rpx rgba(0, 122, 255, 0.14); }
  100% { opacity: 1; transform: translateY(0); }
}

.card-updated {
  animation: card-update 0.65s ease both;
}
