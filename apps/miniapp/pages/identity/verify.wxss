.identity-page {
  min-height: 100vh;
  padding: 24rpx;
  background: #FFF8F0;
}

.hero-card {
  padding: 32rpx 24rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 142, 83, 0.1);
  background: linear-gradient(180deg, #FFFFFF 0%, #FFFCF8 100%);
  color: #2D2A26;
  box-shadow: 0 8rpx 28rpx rgba(45, 42, 38, 0.06);
}

.hero-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1714;
}

.hero-sub {
  display: block;
  margin-top: 10rpx;
  color: #8C857D;
  font-size: 28rpx;
  line-height: 1.5;
}

.status-chip {
  display: inline-flex;
  align-items: center;
  margin-top: 16rpx;
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  background: #F5F2EF;
  color: #8C857D;
}

.status-approved {
  background: linear-gradient(135deg, #E8FFF5 0%, #F0FFF8 100%);
  color: #00A87A;
}

.status-pending {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFF8ED 100%);
  color: #E6A817;
}

.status-rejected {
  background: linear-gradient(135deg, #FFF0F0 0%, #FFF5F5 100%);
  color: #CF1322;
}

.status-unverified {
  background: #F5F2EF;
  color: #8C857D;
}

.section-card {
  margin-top: 20rpx;
  padding: 28rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 142, 83, 0.1);
  background: #FFFFFF;
  box-shadow: 0 4rpx 16rpx rgba(45, 42, 38, 0.04);
}

.section-title {
  display: block;
  margin-bottom: 16rpx;
  color: #1A1714;
  font-size: 32rpx;
  font-weight: 600;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
}

.info-label {
  color: #8C857D;
  font-size: 24rpx;
}

.info-value {
  color: #1A1714;
  font-size: 28rpx;
  font-weight: 500;
}

.form-group {
  margin-top: 14rpx;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  color: #2D2A26;
  font-size: 26rpx;
  font-weight: 600;
}

.inline-row {
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.code-input {
  flex: 1;
}

.code-btn {
  width: 210rpx;
  min-height: 80rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(255, 107, 107, 0.2);
  background: #FFFFFF;
  color: #FF6B6B;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 80rpx;
  transition: transform 0.15s;
}

.code-btn:active {
  transform: scale(0.96);
}

.verify-btn {
  margin-top: 18rpx;
}

.type-grid {
  display: flex;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.type-btn {
  flex: 1;
  min-height: 72rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(255, 142, 83, 0.12);
  background: #FFFFFF;
  color: #8C857D;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 72rpx;
  transition: transform 0.15s;
}

.type-btn:active {
  transform: scale(0.96);
}

.type-btn-active {
  border-color: transparent;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.25);
}

.upload-box {
  margin-bottom: 16rpx;
  padding: 28rpx 20rpx;
  border: 2rpx dashed rgba(255, 142, 83, 0.25);
  border-radius: 18rpx;
  background: linear-gradient(135deg, #FFFCF8 0%, #FFF8F0 100%);
  transition: border-color 0.2s;
}

.upload-box:active {
  border-color: #FF8E53;
}

.upload-title {
  display: block;
  color: #2D2A26;
  font-size: 26rpx;
  font-weight: 700;
}

.upload-sub {
  display: block;
  margin-top: 10rpx;
  color: #8C857D;
  font-size: 23rpx;
}

.note-box {
  margin: 12rpx 0 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #FFF3E0 0%, #FFF8ED 100%);
  border: 1rpx solid rgba(230, 168, 23, 0.1);
}

.note-title {
  display: block;
  color: #E6A817;
  font-size: 24rpx;
  font-weight: 500;
}

.note-content {
  display: block;
  margin-top: 6rpx;
  color: #8C6A00;
  font-size: 24rpx;
  line-height: 1.5;
}
