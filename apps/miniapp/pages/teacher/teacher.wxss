.teacher-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 22rpx;
  padding: 18rpx 4rpx 28rpx;
}

.profile-button,
.action-button,
.apply-button {
  border-radius: 24rpx;
  font-weight: 750;
}

.profile-button {
  width: 128rpx;
  height: 72rpx;
  background: #ffffff;
  color: #007aff;
  font-size: 25rpx;
  line-height: 72rpx;
  box-shadow: 0 12rpx 28rpx rgba(31, 41, 55, 0.09);
}

.top-actions {
  display: flex;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.action-button {
  position: relative;
  flex: 1;
  height: 86rpx;
  background: #ffffff;
  color: #111827;
  font-size: 26rpx;
  line-height: 86rpx;
  box-shadow: 0 12rpx 28rpx rgba(31, 41, 55, 0.08);
}

.primary {
  background: linear-gradient(135deg, #007aff, #34c8ff);
  color: #ffffff;
}

.notification-badge {
  position: absolute;
  top: -10rpx;
  right: 16rpx;
  min-width: 38rpx;
  height: 38rpx;
  padding: 0 8rpx;
  border: 4rpx solid #f5f7fb;
  border-radius: 999rpx;
  background: #ff3b30;
  color: #ffffff;
  font-size: 20rpx;
  line-height: 38rpx;
}

.filter-card {
  padding: 24rpx;
  border-radius: 30rpx;
  background: linear-gradient(145deg, #ffffff, #edf7ff);
  box-shadow: 0 18rpx 44rpx rgba(31, 41, 55, 0.08);
}

.filter-label {
  display: block;
  color: #374151;
  font-size: 24rpx;
  font-weight: 750;
}

.area-label {
  margin-top: 22rpx;
}

.filter-scroll {
  width: 100%;
  margin-top: 14rpx;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 14rpx;
}

.filter-chip {
  min-width: 96rpx;
  height: 62rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #5d6675;
  font-size: 25rpx;
  font-weight: 650;
  line-height: 62rpx;
  text-align: center;
  box-shadow: inset 0 0 0 1rpx rgba(210, 216, 225, 0.8);
}

.filter-active {
  background: #111827;
  color: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(17, 24, 39, 0.18);
}

.demand-main {
  flex: 1;
  min-width: 0;
}

.desc {
  display: block;
  margin-top: 18rpx;
  color: #4b5563;
  font-size: 25rpx;
  line-height: 1.5;
}

.demand-foot {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 22rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf0f4;
  color: #6b7280;
  font-size: 23rpx;
}

.apply-button {
  margin-left: auto;
  min-width: 160rpx;
  height: 66rpx;
  padding: 0 20rpx;
  background: #007aff;
  color: #ffffff;
  font-size: 24rpx;
  line-height: 66rpx;
}

.apply-button[disabled] {
  background: #eef2f7;
  color: #6b7280;
}

.fav-row {
  margin-top: 16rpx;
}

.fav-btn {
  width: 100%;
  min-height: 62rpx;
  border-radius: 18rpx;
  background: #fff7f0;
  color: #c2410c;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 62rpx;
}

.fav-active {
  background: #ff3b30;
  color: #ffffff;
}

@keyframes badge-flash {
  0% { transform: scale(1); }
  25% { transform: scale(1.28); box-shadow: 0 0 0 10rpx rgba(0, 122, 255, 0.16); }
  55% { transform: scale(0.94); }
  100% { transform: scale(1); }
}

.badge-flash {
  animation: badge-flash 0.75s ease both;
}

@keyframes card-leave {
  from { opacity: 1; transform: translateY(0) scale(1); }
  to { opacity: 0; transform: translateY(-18rpx) scale(0.96); }
}

.card-leaving {
  animation: card-leave 0.3s ease forwards;
  pointer-events: none;
}

@keyframes card-update {
  0% { opacity: 0.88; transform: translateY(12rpx); }
  45% { opacity: 1; transform: translateY(0); box-shadow: 0 22rpx 52rpx rgba(0, 122, 255, 0.14); }
  100% { opacity: 1; transform: translateY(0); }
}

.card-updated {
  animation: card-update 0.65s ease both;
}
