.teacher-head {
  position: relative;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 8rpx 0 24rpx;
  overflow: hidden;
}

.hero-text {
  flex: 1;
  min-width: 0;
}

.hero-illustration {
  position: absolute;
  top: -20rpx;
  right: -20rpx;
  width: 180rpx;
  height: 180rpx;
  opacity: 0.18;
  pointer-events: none;
}

.profile-button,
.action-button,
.apply-button {
  border-radius: 16rpx;
  font-weight: 500;
  transition: transform 0.15s;
}

.profile-button:active,
.action-button:active,
.apply-button:active {
  transform: scale(0.95);
}

.profile-button {
  width: 120rpx;
  height: 64rpx;
  border: 2rpx solid #E8E5E0;
  background: #FFFFFF;
  color: #FF6B6B;
  font-size: 24rpx;
  line-height: 64rpx;
}

.top-actions {
  display: flex;
  gap: 14rpx;
  margin-bottom: 24rpx;
}

.nav-card {
  position: relative;
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  height: 140rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  transition: transform 0.15s, box-shadow 0.15s;
}

.nav-card:active {
  transform: scale(0.96);
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.06);
}

.nav-messages {
  background: #F8F6FF;
  border-color: rgba(120, 100, 200, 0.08);
}

.nav-browse {
  background: #FFF7F2;
  border-color: rgba(255, 142, 83, 0.08);
}

.nav-orders {
  background: #F2FFF8;
  border-color: rgba(0, 168, 122, 0.08);
}

.nav-icon-wrap {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-messages .nav-icon-wrap {
  background: rgba(120, 100, 200, 0.12);
}

.nav-browse .nav-icon-wrap {
  background: rgba(255, 142, 83, 0.12);
}

.nav-orders .nav-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  background: rgba(0, 168, 122, 0.18);
}

.nav-icon {
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
}

.nav-messages .nav-icon { color: #6B5DC6; }
.nav-browse .nav-icon { color: #E87A3A; }
.nav-orders .nav-icon { font-size: 28rpx; color: #00875A; }

.nav-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #5A5550;
  line-height: 1;
}

.notification-badge {
  position: absolute;
  top: -6rpx;
  right: -6rpx;
  min-width: 34rpx;
  height: 34rpx;
  padding: 0 8rpx;
  border: 4rpx solid #F8F6FF;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 34rpx;
}

.filter-card {
  padding: 24rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  background: #FFFFFF;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.filter-label {
  display: block;
  color: #2D2A26;
  font-size: 24rpx;
  font-weight: 500;
}

.area-label {
  margin-top: 20rpx;
}

.filter-scroll {
  width: 100%;
  margin-top: 12rpx;
  white-space: nowrap;
}

.filter-row {
  display: inline-flex;
  gap: 10rpx;
}

.filter-chip {
  min-width: 88rpx;
  height: 56rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  border: 2rpx solid #E8E5E0;
  background: #FFFFFF;
  color: #8C857D;
  font-size: 24rpx;
  line-height: 56rpx;
  text-align: center;
  transition: transform 0.15s;
}

.filter-chip:active {
  transform: scale(0.95);
}

.filter-active {
  border-color: transparent;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.2);
}

.demand-main {
  flex: 1;
  min-width: 0;
}

.desc {
  display: block;
  margin-top: 16rpx;
  color: #8C857D;
  font-size: 28rpx;
  line-height: 1.6;
}

.demand-foot {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 18rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(0, 0, 0, 0.04);
  color: #8C857D;
  font-size: 24rpx;
}

.apply-button {
  margin-left: auto;
  min-width: 160rpx;
  height: 64rpx;
  padding: 0 18rpx;
  border: 0;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  font-size: 24rpx;
  line-height: 64rpx;
  box-shadow: 0 4rpx 12rpx rgba(255, 107, 107, 0.2);
}

.foot-status-link {
  margin-left: auto;
  color: #FF6B6B;
  font-size: 24rpx;
  font-weight: 500;
}

.fav-row {
  margin-top: 16rpx;
}

.fav-btn {
  width: 100%;
  min-height: 62rpx;
  border-radius: 16rpx;
  border: 2rpx solid #E8E5E0;
  background: #FFFFFF;
  color: #8C857D;
  font-size: 24rpx;
  font-weight: 500;
  line-height: 62rpx;
  transition: transform 0.15s;
}

.fav-btn:active {
  transform: scale(0.97);
}

.fav-active {
  border-color: rgba(255, 107, 107, 0.3);
  background: #FFF3ED;
  color: #FF6B6B;
}

.card-leaving,
.card-updated {
  opacity: 0.72;
}

.banner-warning {
  background: #FFF8ED;
  color: #B8860B;
  border-color: rgba(184, 134, 11, 0.12);
}

.banner-cta {
  display: inline-block;
  margin-top: 16rpx;
  min-height: 56rpx;
  padding: 0 24rpx;
  border-radius: 14rpx;
  border: 2rpx solid #E8642A;
  background: #FFFFFF;
  color: #E8642A;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 56rpx;
}

.banner-cta:active {
  background: #FFF3ED;
}
