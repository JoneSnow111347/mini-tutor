<view class="page">
  <view class="teacher-head">
    <view class="hero-text"><text class="eyebrow">教师工作台</text><text class="title">{{teacherName}}，你好</text><text class="subtitle">浏览家长需求，查看申请结果并及时接单。</text></view>
    <button class="profile-button" bindtap="goProfile">资料</button>
    <image class="hero-illustration" src="/assets/images/empty/empty-teacher-demand.png" mode="aspectFit" />
  </view>
  <view wx:if="{{verificationStatus !== 'verified'}}" class="status-banner banner-warning"><text class="status-banner-title">{{verificationStatus === 'pending' ? '认证审核中' : verificationStatus === 'rejected' ? '认证未通过' : '请先完成认证'}}</text><text class="status-banner-sub">{{verificationStatus === 'pending' ? '审核通过后即可申请接单，通常需要 1-2 个工作日。' : verificationStatus === 'rejected' ? '请重新上传认证材料，审核通过后即可申请接单。' : '完善资料并通过认证后，才能申请家长发布的家教需求。'}}</text><button class="banner-cta" bindtap="goEditTeacher">{{verificationStatus === 'rejected' ? '重新认证' : '去完善资料'}}</button></view>
  <view wx:if="{{badgeCount > 0}}" class="status-banner banner-info"><text class="status-banner-title">有 {{badgeCount}} 条未读消息</text><text class="status-banner-sub">包含申请结果和新需求通知，点击"消息通知"查看。</text></view>
  <view class="top-actions">
    <button class="nav-card nav-messages" bindtap="goNotifications">
      <view class="nav-icon-wrap"><text class="nav-icon">消</text></view>
      <text class="nav-label">消息通知</text>
      <view wx:if="{{badgeCount > 0}}" class="notification-badge {{badgeFlash ? 'badge-flash' : ''}}">{{badgeCount > 99 ? '99+' : badgeCount}}</view>
    </button>
    <button class="nav-card nav-browse" bindtap="goBrowse">
      <view class="nav-icon-wrap"><text class="nav-icon">需</text></view>
      <text class="nav-label">需求广场</text>
    </button>
    <button class="nav-card nav-orders" bindtap="goMyOrders">
      <view class="nav-icon-wrap"><text class="nav-icon">申</text></view>
      <text class="nav-label">我的申请</text>
    </button>
  </view>
  <view wx:if="{{syncTip}}" class="status-banner banner-info"><text class="status-banner-title">{{syncTip}}</text><text class="status-banner-sub">需求列表已自动刷新。</text></view>
  <view class="filter-card">
    <text class="filter-label">科目</text>
    <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}"><view class="filter-row"><view wx:for="{{subjects}}" wx:key="*this" class="filter-chip {{selectedSubject === item ? 'filter-active' : ''}}" data-value="{{item}}" bindtap="selectSubject">{{item}}</view></view></scroll-view>
    <text class="filter-label area-label">区域</text>
    <scroll-view class="filter-scroll" scroll-x enhanced show-scrollbar="{{false}}"><view class="filter-row"><view wx:for="{{areas}}" wx:key="*this" class="filter-chip {{selectedArea === item ? 'filter-active' : ''}}" data-value="{{item}}" bindtap="selectArea">{{item}}</view></view></scroll-view>
  </view>
  <view class="section-head"><text class="section-title">匹配需求</text><text class="section-link">{{filteredDemands.length}} 条</text></view>
  <view wx:if="{{loading}}" class="empty-tip">正在同步需求...</view>
  <view wx:elif="{{filteredDemands.length === 0}}" class="empty-tip">
    <text class="empty-main">{{verificationStatus !== 'verified' ? '认证通过后可申请需求' : (selectedSubject !== '全部' || selectedArea !== '全部') ? '当前筛选下暂无需求' : '当前暂无可申请需求'}}</text>
    <text class="empty-sub">{{verificationStatus !== 'verified' ? '完善资料并通过认证后即可申请。' : (selectedSubject !== '全部' || selectedArea !== '全部') ? '试试调整筛选条件或稍后再看。' : '有新需求发布时会自动出现在列表中。'}}</text>
  </view>
  <view wx:for="{{filteredDemands}}" wx:key="id" class="card demand-card {{leavingDemandIds[item.id] ? 'card-leaving' : ''}} {{item.statusChanged ? 'card-updated' : ''}}">
    <view class="card-row card-tap" data-id="{{item.id}}" bindtap="goDemandDetail"><view class="demand-main"><text class="card-title">{{item.title}}</text><text class="card-meta">{{item.subject}} · {{item.grade_level}} · {{item.area}}</text></view><text class="badge badge-{{item.applyStatus === 'none' ? 'open' : item.applyStatus === 'pending' ? 'applied' : item.applyStatus}} {{item.statusChanged ? 'badge-flash' : ''}}">{{item.applyText}}</text></view>
    <text class="desc">{{item.description}}</text>
    <view class="demand-foot"><text>{{item.class_mode}}</text><text>{{item.dateText}}</text><button wx:if="{{item.applyStatus === 'none'}}" class="apply-button" data-id="{{item.id}}" catchtap="goDemandDetail">申请接单</button><text wx:else class="foot-status-link" data-id="{{item.id}}" catchtap="goDemandDetail">查看申请 ></text></view>
    <view class="fav-row"><button class="fav-btn {{item.isFav ? 'fav-active' : ''}}" data-id="{{item.id}}" catchtap="toggleFavDemand">{{item.isFav ? '已收藏' : '收藏'}}</button></view>
  </view>
  <button class="global-logout-btn" bindtap="handleGlobalLogout">退出登录</button>
</view>
