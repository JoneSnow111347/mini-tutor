page {
  min-height: 100vh;
  background: #f5f7fb;
  color: #111827;
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
  box-sizing: border-box;
}

view,
text,
input,
textarea,
button {
  box-sizing: border-box;
}

button::after {
  border: 0;
}

.container,
.page {
  min-height: 100vh;
  padding: 32rpx;
  background: #f5f7fb;
}

.ios-hero {
  padding: 18rpx 4rpx 28rpx;
}

.eyebrow {
  display: block;
  color: #007aff;
  font-size: 24rpx;
  font-weight: 700;
}

.title {
  display: block;
  margin-top: 8rpx;
  color: #111827;
  font-size: 52rpx;
  font-weight: 750;
  line-height: 1.12;
  letter-spacing: 0;
}

.subtitle {
  display: block;
  margin-top: 12rpx;
  color: #6b7280;
  font-size: 27rpx;
  line-height: 1.45;
}

.card {
  margin-bottom: 22rpx;
  padding: 28rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.96);
  box-shadow: 0 18rpx 46rpx rgba(31, 41, 55, 0.08);
}

.card-tap:active {
  transform: scale(0.99);
  background: #f8fafc;
}

.card-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.card-title {
  display: block;
  color: #111827;
  font-size: 31rpx;
  font-weight: 750;
  line-height: 1.35;
}

.card-meta {
  display: block;
  margin-top: 8rpx;
  color: #6b7280;
  font-size: 24rpx;
  line-height: 1.45;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 34rpx 4rpx 18rpx;
}

.section-title {
  display: block;
  color: #111827;
  font-size: 31rpx;
  font-weight: 750;
  line-height: 1.25;
}

.section-link {
  color: #007aff;
  font-size: 25rpx;
  font-weight: 650;
}

.form-group {
  margin-bottom: 26rpx;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  color: #374151;
  font-size: 25rpx;
  font-weight: 650;
}

.required {
  margin-left: 4rpx;
  color: #ff3b30;
}

.form-input,
.form-textarea {
  width: 100%;
  border: 1rpx solid #e5e7eb;
  border-radius: 24rpx;
  background: #ffffff;
  color: #111827;
  font-size: 29rpx;
}

.form-input {
  height: 92rpx;
  padding: 0 26rpx;
}

.form-textarea {
  min-height: 214rpx;
  padding: 22rpx 26rpx;
  line-height: 1.55;
}

.placeholder {
  color: #a6afbd;
}

.form-hint,
.char-count {
  display: block;
  margin-top: 10rpx;
  color: #9ca3af;
  font-size: 23rpx;
}

.char-count {
  text-align: right;
}

.btn-primary,
.btn-secondary,
.btn-danger,
.btn-success {
  min-height: 88rpx;
  border-radius: 24rpx;
  padding: 0 28rpx;
  font-size: 29rpx;
  font-weight: 750;
  line-height: 88rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #007aff, #34c8ff);
  color: #ffffff;
  box-shadow: 0 18rpx 34rpx rgba(0, 122, 255, 0.24);
}

.btn-secondary {
  background: #ffffff;
  color: #007aff;
  box-shadow: 0 12rpx 28rpx rgba(31, 41, 55, 0.08);
}

.btn-danger {
  background: #ff3b30;
  color: #ffffff;
}

.btn-success {
  background: #34c759;
  color: #ffffff;
}

.btn-sm {
  min-height: 66rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  font-size: 25rpx;
  line-height: 66rpx;
}

button[disabled] {
  opacity: 0.58;
  box-shadow: none;
}

.tag-row,
.badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #eef5ff;
  color: #006edb;
  font-size: 23rpx;
  font-weight: 650;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 750;
  white-space: nowrap;
}

.badge-open { background: #eaf8ef; color: #16833a; }
.badge-closed { background: #eef0f4; color: #6b7280; }
.badge-pending { background: #fff7e6; color: #b76e00; }
.badge-accepted { background: #eaf8ef; color: #16833a; }
.badge-rejected { background: #fff0f0; color: #d92d20; }
.badge-verified { background: #e8f2ff; color: #006edb; }
.badge-applied { background: #f0ebff; color: #6750d8; }
.badge-new { background: #fff1e6; color: #c2410c; animation: pulse 1.5s ease-in-out infinite; }

.notification-badge,
.dot-badge {
  animation: badge-pop 0.32s ease both, pulse 1.8s ease-in-out infinite 0.35s;
}

.badge-flash {
  animation: shared-badge-flash 0.75s ease both;
}

.card-updated {
  animation: shared-card-update 0.65s ease both;
}

.empty-tip {
  display: block;
  padding: 82rpx 24rpx;
  color: #9ca3af;
  font-size: 27rpx;
  line-height: 1.45;
  text-align: center;
}

.status-banner {
  margin-bottom: 22rpx;
  padding: 24rpx 26rpx;
  border-radius: 26rpx;
  animation: slide-down 0.3s ease both;
}

.status-banner-title {
  display: block;
  font-size: 29rpx;
  font-weight: 750;
  line-height: 1.35;
}

.status-banner-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.45;
}

.banner-info { background: #e8f2ff; color: #0057b8; }
.banner-success { background: #eaf8ef; color: #16833a; }
.banner-danger { background: #fff0f0; color: #d92d20; }

@keyframes badge-pop {
  0% { opacity: 0; transform: scale(0.6); }
  70% { opacity: 1; transform: scale(1.12); }
  100% { opacity: 1; transform: scale(1); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.08); opacity: 0.82; }
}

@keyframes slide-down {
  from { opacity: 0; transform: translateY(-24rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes shared-badge-flash {
  0% { transform: scale(1); }
  24% { transform: scale(1.3); box-shadow: 0 0 0 10rpx rgba(0, 122, 255, 0.16); }
  55% { transform: scale(0.94); }
  100% { transform: scale(1); }
}

@keyframes shared-card-update {
  0% { opacity: 0.88; transform: translateY(12rpx); }
  45% { opacity: 1; transform: translateY(0); box-shadow: 0 22rpx 52rpx rgba(0, 122, 255, 0.14); }
  100% { opacity: 1; transform: translateY(0); }
}

.global-logout-btn {
  position: fixed;
  right: 28rpx;
  bottom: calc(env(safe-area-inset-bottom) + 28rpx);
  z-index: 40;
  min-height: 72rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: rgba(17, 24, 39, 0.9);
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 72rpx;
  box-shadow: 0 14rpx 32rpx rgba(17, 24, 39, 0.18);
}

