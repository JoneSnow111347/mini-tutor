page {
  min-height: 100vh;
  background: #F7F6F3;
  color: #2D2A26;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
  box-sizing: border-box;
}

view,
text,
input,
textarea,
button,
scroll-view,
picker,
switch {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
}

button::after {
  border: 0;
}

.container,
.page {
  min-height: 100vh;
  padding: 32rpx 24rpx 40rpx;
  background: #F7F6F3;
}

/* ========== HERO / HEADER ========== */

.ios-hero,
.auth-header {
  padding: 12rpx 0 28rpx;
}

.auth-header {
  text-align: center;
}

.auth-icon,
.app-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto 20rpx;
  border-radius: 20rpx;
  border: 0;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1;
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 107, 0.2);
}

.eyebrow {
  display: inline-block;
  min-height: 44rpx;
  margin-bottom: 14rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #FFF3ED;
  color: #E8642A;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 44rpx;
}

.title,
.auth-title {
  display: block;
  margin-top: 8rpx;
  color: #1A1714;
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.3;
}

.subtitle,
.auth-sub {
  display: block;
  margin-top: 10rpx;
  color: #8C857D;
  font-size: 26rpx;
  line-height: 1.6;
}

/* ========== CARDS ========== */

.card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.04);
  border-radius: 28rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.card-tap:active,
.card:active {
  background: #FAFAF8;
  transform: scale(0.985);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.card-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.card-title {
  display: block;
  color: #1A1714;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
}

.card-meta {
  display: block;
  margin-top: 8rpx;
  color: #8C857D;
  font-size: 24rpx;
  line-height: 1.5;
}

/* ========== SECTION HEADERS ========== */

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 28rpx 0 16rpx;
}

.section-title {
  display: block;
  color: #1A1714;
  font-size: 32rpx;
  font-weight: 600;
  line-height: 1.4;
}

.section-link {
  color: #FF6B6B;
  font-size: 24rpx;
  font-weight: 500;
}

/* ========== FORMS ========== */

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  margin-bottom: 12rpx;
  color: #2D2A26;
  font-size: 28rpx;
  font-weight: 500;
  line-height: 1.5;
}

.required {
  margin-left: 4rpx;
  color: #FF4D4F;
}

.form-input,
.form-textarea {
  width: 100%;
  border: 2rpx solid #E8E5E0;
  border-radius: 18rpx;
  background: #FAFAF8;
  color: #2D2A26;
  font-size: 28rpx;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.form-input:focus,
.form-textarea:focus {
  border-color: #FF8E53;
  box-shadow: 0 0 0 4rpx rgba(255, 142, 83, 0.06);
}

.form-input {
  height: 88rpx;
  padding: 0 24rpx;
}

.form-textarea {
  min-height: 200rpx;
  padding: 20rpx 24rpx;
  line-height: 1.6;
}

.placeholder {
  color: #C4BDB5;
}

.form-hint,
.char-count {
  display: block;
  margin-top: 8rpx;
  color: #9A938B;
  font-size: 24rpx;
  line-height: 1.5;
}

.char-count {
  text-align: right;
}

/* ========== BUTTONS ========== */

.btn-primary,
.btn-secondary,
.btn-danger,
.btn-success {
  min-height: 80rpx;
  padding: 0 24rpx;
  border-radius: 18rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 80rpx;
  text-align: center;
  transition: transform 0.15s, opacity 0.15s, box-shadow 0.15s;
}

.btn-primary {
  border: 0;
  background: linear-gradient(135deg, #FF6B6B 0%, #FF8E53 100%);
  color: #ffffff;
  box-shadow: 0 6rpx 16rpx rgba(255, 107, 107, 0.2);
}

.btn-primary:active {
  transform: scale(0.96);
  opacity: 0.9;
  box-shadow: 0 3rpx 8rpx rgba(255, 107, 107, 0.15);
}

.btn-secondary {
  border: 2rpx solid #E8E5E0;
  background: #FFFFFF;
  color: #FF6B6B;
}

.btn-secondary:active {
  transform: scale(0.96);
  background: #FAFAF8;
}

.btn-danger {
  border: 2rpx solid rgba(255, 77, 79, 0.2);
  background: #FFF1F0;
  color: #CF1322;
}

.btn-danger:active {
  transform: scale(0.96);
  opacity: 0.85;
}

.btn-success {
  border: 2rpx solid rgba(0, 201, 167, 0.2);
  background: #F0FFF8;
  color: #00A87A;
}

.btn-success:active {
  transform: scale(0.96);
  opacity: 0.85;
}

.btn-sm {
  min-height: 64rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  line-height: 64rpx;
}

button[disabled] {
  opacity: 0.45;
}

/* ========== TAGS & BADGES ========== */

.tag-row,
.badge-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #FFF3ED;
  color: #C0713A;
  font-size: 24rpx;
  line-height: 40rpx;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 40rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  font-weight: 500;
  white-space: nowrap;
}

.badge-open,
.badge-verified,
.badge-applied,
.badge-new {
  background: #FFF3ED;
  color: #E8642A;
}

.badge-closed {
  background: #F2F0ED;
  color: #8C857D;
}

.badge-pending {
  background: #FFF8ED;
  color: #E6A817;
}

.badge-accepted {
  background: #E8FFF5;
  color: #00A87A;
}

.badge-rejected {
  background: #FFF0F0;
  color: #CF1322;
}

/* ========== EMPTY STATE ========== */

.empty-tip {
  display: block;
  padding: 72rpx 24rpx;
  color: #9A938B;
  font-size: 24rpx;
  line-height: 1.6;
  text-align: center;
}

/* ========== STATUS BANNERS ========== */

.status-banner {
  margin-bottom: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  border: 1rpx solid transparent;
}

.status-banner-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1.5;
}

.status-banner-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.banner-info {
  background: #FFF3ED;
  color: #E8642A;
  border-color: rgba(232, 100, 42, 0.12);
}

.banner-success {
  background: #E8FFF5;
  color: #00A87A;
  border-color: rgba(0, 168, 122, 0.12);
}

.banner-danger {
  background: #FFF0F0;
  color: #CF1322;
  border-color: rgba(207, 19, 34, 0.12);
}

/* ========== LOGOUT BUTTON ========== */

.global-logout-btn {
  position: fixed;
  right: 24rpx;
  bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  z-index: 40;
  min-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 1rpx solid #E8E5E0;
  background: rgba(255, 255, 255, 0.9);
  color: #8C857D;
  font-size: 24rpx;
  line-height: 64rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.global-logout-btn:active {
  transform: scale(0.95);
  opacity: 0.8;
}

/* ========== ANIMATIONS ========== */

@keyframes badge-flash-anim {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.badge-flash {
  animation: badge-flash-anim 1.2s ease-in-out 2;
}

.badge-flash-anim {
  animation: badge-flash-anim 1.2s ease-in-out 2;
}

@keyframes fade-in-up {
  from {
    opacity: 0;
    transform: translateY(16rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.card {
  animation: fade-in-up 0.3s ease-out;
}
